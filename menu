#!/bin/bash
# =========================================================
#             SCRIPT CENTRAL: VPS-SAMA PREMIUM
# =========================================================
clear
clear
sudo sysctl -w net.ipv6.conf.all.disable_ipv6=1 >/dev/null 2>&1
sudo sysctl -w net.ipv6.conf.default.disable_ipv6=1 >/dev/null 2>&1
sudo sysctl -w net.ipv6.conf.lo.disable_ipv6=1 >/dev/null 2>&1

# COLORES
red=$(tput setaf 1)
gren=$(tput setaf 2)
yellow=$(tput setaf 3)

SCPdir="/etc/VPS-SAMA" && [[ ! -d ${SCPdir} ]] && mkdir -p ${SCPdir}
touch /etc/VPS-SAMA/usuarios.db
touch /etc/VPS-SAMA/v2ray_usuarios.db

# Configuración inicial de la Clave Token y Slogan si no existen
[[ ! -f "/etc/VPS-SAMA/token.key" ]] && echo "sama123" > /etc/VPS-SAMA/token.key
[[ ! -f "/etc/VPS-SAMA/message.txt" ]] && echo "VPS-SAMA PREMIUM" > /etc/VPS-SAMA/message.txt

# RENDIMIENTO DE MEMORIA Y PROCESADOR
_core=$(printf '%-1s' "$(grep -c cpu[0-9] /proc/stat)")
_usop=$(top -bn1 | sed -rn '3s/[^0-9]* ([0-9\.]+) .*/\1/p;4s/.*, ([0-9]+) .*/\1/p' | tr '\n' ' ')
_usor=$(printf '%-8s' "$(free -m | awk 'NR==2{printf "%.2f%%", $3*100/$2 }')")

msg() {
   NEGRITO='\e[1m' && SEMCOR='\e[0m'
   COLOR[0]='\033[1;37m' # Blanco
   COLOR[1]='\e[31m'     # Rojo
   COLOR[2]='\e[32m'     # Verde
   COLOR[3]='\e[33m'     # Amarillo
   COLOR[6]='\033[1;97m' # Cyan Brillante
   case $1 in
   -ne) cor="${COLOR[1]}${NEGRITO}" && echo -ne "${cor}${2}${SEMCOR}" ;;
   -ama) cor="${COLOR[3]}${NEGRITO}" && echo -e "${cor}${2}${SEMCOR}" ;;
   -azu) cor="${COLOR[6]}${NEGRITO}" && echo -e "${cor}${2}${SEMCOR}" ;;
   -verd) cor="${COLOR[2]}${NEGRITO}" && echo -e "${cor}${2}${SEMCOR}" ;;
   "-bar2" | "-bar") cor="${COLOR[1]}————————————————————————————————————————————————————" && echo -e "${SEMCOR}${cor}${SEMCOR}" ;;
   -tit) echo -e "\e[97m \033[1;41m| #-#-► 🐲 SCRIPT VPS-SAMA PREMIUM ◄-#-# | \033[0;37m" ;;
   esac
}

meu_ip() {
   if [[ -e /etc/VPS-SAMA/MEUIPvps ]]; then
      echo "$(cat /etc/VPS-SAMA/MEUIPvps)"
   else
      MEU_IP=$(curl -sS https://api.ipify.org || curl -sS https://ifconfig.me/ip || wget -qO- ipinfo.io/ip)
      echo "$MEU_IP" | tr -d '[:space:]' > /etc/VPS-SAMA/MEUIPvps
      echo "$MEU_IP"
   fi
}

os_system() {
   system=$(echo $(cat -n /etc/issue | grep 1 | cut -d' ' -f6,7,8 | sed 's/1//' | sed 's/      //'))
   echo $system | awk '{print $1, $2}'
}

selection_fun() {
   local selection="null" && local range
   for ((i = 0; i <= $1; i++)); do range[$i]="$i "; done
   while [[ ! $(echo ${range[*]} | grep -w "$selection") ]]; do
      echo -ne "\033[1;37m ► Selecione una Opcion: " >&2
      read selection
      tput cuu1 >&2 && tput dl1 >&2
   done
   echo $selection
}

# =========================================================
#  SISTEMA DINÁMICO DE RECONSTRUCCIÓN Y PUERTOS PARA V2RAY
# =========================================================
rebuild_v2ray_config() {
   local port_v2ray=$(cat /etc/VPS-SAMA/v2ray.port 2>/dev/null || echo "4433")
   [[ ! -f /usr/local/etc/xray/config.json ]] && return
   
   local clients_json=""
   if [[ -s /etc/VPS-SAMA/v2ray_usuarios.db ]]; then
      while IFS='|' read -r user id exp; do
         clients_json="${clients_json}{\"id\": \"${id}\", \"email\": \"${user}\"},"
      done < /etc/VPS-SAMA/v2ray_usuarios.db
      clients_json="${clients_json%,}"
   fi
   
   cat <<EOF > /usr/local/etc/xray/config.json
{
  "log": { "loglevel": "warning" },
  "inbounds": [{
    "port": ${port_v2ray},
    "protocol": "vless",
    "settings": { "clients": [ ${clients_json} ], "decryption": "none" },
    "streamSettings": { "network": "ws", "wsSettings": { "path": "/vps-sama" } }
  }],
  "outbounds": [{ "protocol": "freedom" }]
}
EOF
   systemctl restart xray >/dev/null 2>&1
}

# =========================================================
# [1] GESTIÓN SSH / TOKEN
# =========================================================
administrar_cuentas_sama() {
   clear && msg -bar
   local CLAVE_TOKEN_ACTUAL=$(cat /etc/VPS-SAMA/token.key)
   echo -e "      \e[1;36m| #-#-► 🐲 GESTIÓN SSH Y TOKENS ◄-#-# |\e[0m"
   msg -bar
   echo -e "      \033[1;37mClave Token Activa de Red: \033[1;93m$CLAVE_TOKEN_ACTUAL\e[0m"
   msg -bar
   echo -ne " \033[1;32m [1] \033[1;31m=>> \033[1;37mNORMAL (Usuario y Contraseña)\n"
   echo -ne " \033[1;32m [2] \033[1;31m=>> \033[1;37mHWID   (Bloqueo por ID de celular)\n"
   echo -ne " \033[1;32m [3] \033[1;31m=>> \033[1;37mTOKEN  (Token Manual sin escribir Clave)\n"
   echo -ne " \033[1;32m [4] \033[1;37m=>> \033[1;31mREMOVER USUARIO O TOKEN DEL SISTEMA\n"
   echo -ne " \033[1;32m [5] \033[1;37m=>> \033[1;37mLISTAR TODAS LAS CUENTAS REGISTRADAS\n"
   echo -ne " \033[1;32m [6] \033[1;37m=>> \033[1;37mEDITAR LA CLAVE TOKEN FIJA\n"
   echo -ne " \033[1;32m [0] \033[1;31m=>> \033[1;41m VOLVER AL MENÚ CENTRAL \033[0m\n"
   msg -bar
   
   local op_db=$(selection_fun 6)
   case $op_db in
   1)
      msg -bar
      while true; do read -p " Nombre de usuario (Máx 16): " user; [[ ${#user} -le 16 && ! -z "$user" ]] && break || echo -e " \e[1;31m[!] Inválido.\e[0m"; done
      while true; do read -p " Contraseña (Máx 16): " pass; [[ ${#pass} -le 16 && ! -z "$pass" ]] && break || echo -e " \e[1;31m[!] Inválida.\e[0m"; done
      read -p " Días de duración: " dias
      useradd -M -s /bin/false -e "$(date -d "$dias days" +"%Y-%m-%d")" $user && echo "$user:$pass" | chpasswd
      echo "$user|NORMAL|$pass|$(date -d "$dias days" +"%d/%m/%Y")" >> /etc/VPS-SAMA/usuarios.db
      echo -e "\e[1;32m\n [+] Registrado con éxito.\e[0m" && read -p " Presione Enter..." ;;
   2)
      msg -bar
      while true; do read -p " Nombre de usuario (Máx 16): " user; [[ ${#user} -le 16 && ! -z "$user" ]] && break || echo -e " \e[1;31m[!] Inválido.\e[0m"; done
      read -p " Pegue el HWID: " hwid && read -p " Días: " dias
      useradd -M -s /bin/false -e "$(date -d "$dias days" +"%Y-%m-%d")" $user && echo "$user:hwidsama123" | chpasswd
      echo "$user|HWID|$hwid|$(date -d "$dias days" +"%d/%m/%Y")" >> /etc/VPS-SAMA/usuarios.db
      echo -e "\e[1;32m\n [+] Registrado con éxito.\e[0m" && read -p " Presione Enter..." ;;
   3)
      msg -bar
      echo -ne " \033[1;32m[*] \033[1;31m=>> \033[1;37mNombre del Cliente: " && read cliente_nom
      while true; do
         echo -ne " \033[1;32m[*] \033[1;31m=>> \033[1;37mIngrese o pegue el TOKEN (Máx 16): " && read token_manual
         [[ ${#token_manual} -le 16 && ! -z "$token_manual" ]] && break || echo -e " \e[1;31m     [!] Largo incorrecto.\e[0m"
      done
      echo -ne " \033[1;32m[*] \033[1;31m=>> \033[1;37mDías de duración: " && read dias
      local clave_uni=$(cat /etc/VPS-SAMA/token.key)
      cliente_nom=$(echo "$cliente_nom" | sed 's/ /_/g') && [[ -z "$cliente_nom" ]] && cliente_nom="Sin_Nombre"
      useradd -M -s /bin/false -e "$(date -d "$dias days" +"%Y-%m-%d")" $token_manual && echo "$token_manual:$clave_uni" | chpasswd
      echo "$token_manual|TOKEN|$clave_uni|$(date -d "$dias days" +"%d/%m/%Y")|$cliente_nom" >> /etc/VPS-SAMA/usuarios.db
      echo -e "\e[1;32m\n [+] ¡TOKEN MANUAL REGISTRADO CON ÉXITO!\e[0m" && read -p " Presione Enter..." ;;
   4)
      clear && msg -bar && echo -e "         \e[1;31m🚨 GESTOR DE BAJAS DE CUENTAS / TOKENS 🚨\e[0m" && msg -bar
      if [[ ! -s /etc/VPS-SAMA/usuarios.db ]]; then echo -e " \e[1;31m[-] No hay usuarios.\e[0m" && msg -bar && read -p " Presione Enter..." && return 0; fi
      local i=1 && declare -A lista_users
      while IFS='|' read -r u t c v n; do
         printf "  \e[1;32m[%02d]\e[1;31m => Gram \e[1;37m%-15s \e[1;33m%-8s \e[1;35m(Dueño: %s)\e[0m\n" "$i" "$u" "$t" "$n"
         lista_users[$i]="$u" && i=$((i+1))
      done < /etc/VPS-SAMA/usuarios.db
      echo " ————————————————————————————————————————————————————"
      echo -ne " \033[1;32m[*] \033[1;31m=>> \033[1;37mSeleccione número a borrar: " && read num_elim
      local usuario_seleccionado="${lista_users[$num_elim]}"
      if [[ -z "$usuario_seleccionado" ]]; then echo -e "\e[1;31m\n [-] Inválido.\e[0m" && read -p " Presione Enter..." && return 0; fi
      msg -bar && echo -ne " \033[1;32m[*] \033[1;31m=>> \033[1;33m¿Seguro de borrar a $usuario_seleccionado? (s/n): \033[0m" && read confirm_user
      if [[ "$confirm_user" = "s" || "$confirm_user" = "S" ]]; then
         userdel -f "$usuario_seleccionado" >/dev/null 2>&1
         sed -i "/^$usuario_seleccionado|/d" /etc/VPS-SAMA/usuarios.db
         echo -e "\e[1;32m\n [+] Removido.\e[0m"
      fi
      read -p " Presione Enter..." ;;
   5)
      clear && echo -e "\e[1;36m┌────────────────────────────────────────────────────────┐\e[0m"
      printf " \e[1;33m%-16s %-8s %-12s %-12s %-12s\e[0m\n" "USUARIO/TOKEN" "TIPO" "CLAVE" "VENCIMIENTO" "DUEÑO"
      echo " ————————————————————————————————————————————————————"
      while IFS='|' read -r u t c v n; do [[ -z "$n" ]] && n="—"; printf " %-16s %-8s %-12s %-12s %-12s\n" "$u" "$t" "$c" "$v" "$n"; done < /etc/VPS-SAMA/usuarios.db
      echo " ————————————————————————————————————————————————————" && read -p " Presione Enter..." ;;
   6)
      msg -bar && read -p " Ingrese la NUEVA Clave Fija de Tokens: " nueva_key
      [[ ! -z "$nueva_key" && ${#nueva_key} -le 16 ]] && echo "$nueva_key" > /etc/VPS-SAMA/token.key && echo -e "\e[1;32m\n [+] Cambiada.\e[0m" || echo -e "\e[1;31m[!] Error.\e[0m"
      read -p " Presione Enter..." ;;
   esac
}

# =========================================================
# [2] MOTOR EXCLUSIVO V2RAY / XRAY CON PUERTO ASIGNABLE
# =========================================================
gestionar_v2ray_sama() {
   clear && msg -bar
   echo -e "      \e[1;36m| #-#-► ⚙️ CONTROL V2RAY / XRAY WS ⚙️ ◄-#-# |\e[0m"
   msg -bar
   echo -ne " \033[1;32m [1] \033[1;31m=>> \033[1;37mASIGNAR/CAMBIAR EL PUERTO EN VIVO DE V2RAY\n"
   echo -ne " \033[1;32m [2] \033[1;31m=>> \033[1;37mAGREGAR NUEVO USUARIO V2RAY (UUID)\n"
   echo -ne " \033[1;32m [3] \033[1;31m=>> \033[1;37mELIMINAR USUARIO V2RAY DEL PANEL\n"
   echo -ne " \033[1;32m [4] \033[1;37m=>> \033[1;37mVER USUARIOS ACTIVOS Y LINKS CONFIG\n"
   echo -ne " \033[1;32m [0] \033[1;31m=>> \033[1;41m VOLVER AL MENÚ CENTRAL \033[0m\n"
   msg -bar
   
   local op_v2=$(selection_fun 4)
   case $op_v2 in
   1)
      msg -bar
      local p_actual=$(cat /etc/VPS-SAMA/v2ray.port 2>/dev/null || echo "4433")
      echo -e " \e[1;37mPuerto V2Ray actual:\e[1;33m $p_actual\e[0m"
      echo -ne " \033[1;32m[*] \033[1;31m=>> \033[1;37mIngrese el NUEVO puerto que desea para V2Ray: "
      read nuevo_pv2
      if [[ ! -z "$nuevo_pv2" ]]; then
         echo "$nuevo_pv2" > /etc/VPS-SAMA/v2ray.port
         rebuild_v2ray_config
         echo -e " \e[1;32m[+] Puerto asignado y Xray reiniciado de forma manual.\e[0m"
      fi
      read -p " Enter..." ;;
   2)
      msg -bar
      echo -ne " \033[1;32m[*] \033[1;31m=>> \033[1;37mNombre del cliente para V2Ray: " && read v2user
      echo -ne " \033[1;32m[*] \033[1;31m=>> \033[1;37mDías de duración: " && read v2dias
      [[ -z "$v2user" ]] && return 0
      
      local uuid_gen=$(cat /proc/sys/kernel/random/uuid)
      local expiration=$(date -d "$v2dias days" +"%d/%m/%Y")
      local current_v2port=$(cat /etc/VPS-SAMA/v2ray.port 2>/dev/null || echo "4433")
      
      echo "$v2user|$uuid_gen|$expiration" >> /etc/VPS-SAMA/v2ray_usuarios.db
      rebuild_v2ray_config
      
      local my_ip=$(meu_ip)
      local link_v2ray="vless://${uuid_gen}@${my_ip}:${current_v2port}?type=ws&path=%2Fvps-sama&encryption=none#${v2user}"
      
      echo -e "\e[1;32m\n [+] ¡USUARIO V2RAY REGISTRADO! \e[0m"
      echo -e "     \e[1;37mLink listo:\e[1;33m $link_v2ray \e[0m"
      read -p " Presione Enter..." ;;
   3)
      msg -bar
      if [[ ! -s /etc/VPS-SAMA/v2ray_usuarios.db ]]; then echo -e " \e[1;31m[-] No hay usuarios.\e[0m" && read -p " Enter..." && return 0; fi
      local c=1 && declare -A v2_list
      while IFS='|' read -r user id exp; do
         printf "  \e[1;32m[%02d]\e[1;31m =>> \e[1;37m%s \e[1;35m(Vence: %s)\e[0m\n" "$c" "$user" "$exp"
         v2_list[$c]="$user" && c=$((c+1))
      done < /etc/VPS-SAMA/v2ray_usuarios.db
      read -p " Seleccione número a borrar: " n_del
      local v2_del="${v2_list[$n_del]}"
      if [[ ! -z "$v2_del" ]]; then
         sed -i "/^$v2_del|/d" /etc/VPS-SAMA/v2ray_usuarios.db
         rebuild_v2ray_config
         echo -e "\e[1;31m[-] Removido de la red.\e[0m"
      fi
      read -p " Enter..." ;;
   4)
      clear && msg -bar && echo -e "         \e[1;36m📋 LISTADO DE LLAVES V2RAY ACTIVAS 📋\e[0m" && msg -bar
      local my_ip=$(meu_ip)
      local current_v2port=$(cat /etc/VPS-SAMA/v2ray.port 2>/dev/null || echo "4433")
      while IFS='|' read -r user id exp; do
         echo -e " \e[1;32m• Cliente:\e[1;37m $user \e[1;33m(Vence: $exp)\e[0m"
         echo -e " \e[1;35m  Link:\e[1;30m vless://${id}@${my_ip}:${current_v2port}?type=ws&path=%2Fvps-sama&encryption=none#${user}\n"
      done < /etc/VPS-SAMA/v2ray_usuarios.db
      msg -bar && read -p " Presione Enter..." ;;
   esac
}

# =========================================================
# [3] INDEPENDIZAR PUERTOS EN PROTOCOLOS SOCKS / SSL / DNS
# =========================================================
protocolos_dinamicos_sama() {
   clear && msg -bar
   echo -e "         \e[1;36m⚙️ CONTROL INDEPENDIENTE DE PROTOCOLOS ⚙️\e[0m"
   msg -bar
   echo -e "  \e[1;32m[1]\e[1;37m > Configurar Proxy SOCKS PYTHON / WEBSOCKET"
   echo -e "  \e[1;32m[2]\e[1;37m > Configurar Servidor SSL / TLS (STUNNEL4)"
   echo -e "  \e[1;32m[3]\e[1;37m > Configurar Servidor SLOW DNS (Método Sin Saldo)"
   echo -e "  \e[1;32m[0]\e[1;37m > Volver al Menú Central"
   msg -bar
   read -p " Seleccione una opción: " sub_op
   
   if [[ "$sub_op" = "1" ]]; then
      msg -bar
      echo -ne " \033[1;32m[*] \033[1;31m=>> \033[1;37mIngrese el PUERTO que desea abrir para WebSocket: "
      read p_ws
      if [[ ! -z "$p_ws" ]]; then
         pkill -f PDirect.py
         # Lanzar el payload directo en el puerto manual seleccionado
         screen -dmS ws_sama python3 /etc/VPS-SAMA/protocolos/PDirect.py $p_ws
         echo -e " \e[1;32m[+] WebSocket encendido manualmente en el puerto: $p_ws\e[0m"
      fi
      read -p " Enter..."
   fi
   
   if [[ "$sub_op" = "2" ]]; then
      msg -bar
      echo -ne " \033[1;32m[*] \033[1;31m=>> \033[1;37mIngrese el PUERTO que desea abrir para SSL (Stunnel): "
      read p_ssl
      if [[ ! -z "$p_ssl" ]]; then
         systemctl stop stunnel4 >/dev/null 2>&1
         cat <<EOF > /etc/stunnel/stunnel.conf
pid = /var/run/stunnel4.pid
cert = /etc/stunnel/stunnel.pem
[ssh]
accept = ${p_ssl}
connect = 127.0.0.1:22
EOF
         systemctl start stunnel4 >/dev/null 2>&1
         echo -e " \e[1;32m[+] SSL / TLS activado a mano en el puerto: $p_ssl\e[0m"
      fi
      read -p " Enter..."
   fi
   
   if [[ "$sub_op" = "3" ]]; then
      # SlowDNS maneja por defecto el túnel NS en el puerto 53 de red
      bash /etc/VPS-SAMA/protocolos/slowdns.sh
   fi
}

# =========================================================
# [4] SEGURIDAD EXTRAS (ESTILO COMPLETO VPS-MX)
# =========================================================
herramientas_avanzadas_sama() {
   clear && msg -bar
   echo -e "         \e[1;36m⚙️ SUB-MENÚ DE AJUSTES Y HERRAMIENTAS ⚙️\e[0m"
   msg -bar
   echo -e "  \e[1;32m[1]\e[1;37m > Ver Lista de Puertos Activos (MONITOR LIST)"
   echo -e "  \e[1;32m[2]\e[1;37m > Optimizar Sistema y Activar Acelerador TCP BBR"
   echo -e "  \e[1;32m[3]\e[1;37m > Bloquear Descargas Torrent / P2P (Anti-Bajas)"
   echo -e "  \e[1;32m[4]\e[1;37m > Programar Reinicio Nocturno de RAM (3:00 AM)"
   echo -e "  \e[1;32m[5]\e[1;37m > Cambiar Slogan / Título del Panel Control"
   echo -e "  \e[1;32m[0]\e[1;37m > Volver al Menú Principal"
   msg -bar
   read -p " Seleccione una opción: " sub_her
   
   case $sub_her in
   1) bash /etc/VPS-SAMA/herramientas/ports.sh ;;
   2) bash /etc/VPS-SAMA/herramientas/tcp.sh ;;
   3)
      clear && msg -bar && echo -e " \e[1;31m[+] Configurando Firewall Anti-Torrents (P2P)...\e[0m"
      iptables -A FORWARD -m string --algo bm --string "bitget" -j DROP
      iptables -A FORWARD -m string --algo bm --string "announce.php?pass=" -j DROP
      iptables -A FORWARD -m string --algo bm --string "torrent" -j DROP
      echo -e "\e[1;32m[+] Puertos Torrent bloqueados con éxito de su red.\e[0m" && read -p " Enter..." ;;
   4)
      clear && msg -bar
      sed -i '/reboot/d' /etc/crontab
      echo "0 3 * * * root /sbin/reboot" >> /etc/crontab
      echo -e "\e[1;32m[+] Tarea Cron asignada. El VPS se limpiará a las 3:00 AM.\e[0m" && read -p " Enter..." ;;
   5)
      clear && msg -bar
      read -p " Ingrese el nuevo nombre/marca para su Panel: " nuevo_slogan
      [[ ! -z "$nuevo_slogan" ]] && echo "$nuevo_slogan" > /etc/VPS-SAMA/message.txt
      echo -e "\e[1;32m[+] Slogan cambiado.\e[0m" && read -p " Enter..." ;;
   esac
}

# =========================================================
#             INTERFAZ GRÁFICA PRINCIPAL (TERMINAL)
# =========================================================
clear && msg -bar && msg -tit && msg -bar
title=$(cat ${SCPdir}/message.txt)
echo -e "      \e[1;36mSlogan / Marca: $title\e[0m"
msg -bar
echo -e "      \033[1;37mIP VPS: \033[1;93m$(meu_ip)     \033[1;37mSISTEMA O.S: \033[1;96m$(os_system)"
echo -e "      \033[1;37mNÚCLEOS CPU: \033[1;32m$_core       \033[1;37mUSO RAM: \033[1;32m$_usor"
msg -bar

echo -ne " \033[1;32m [1] \033[1;31m=>> \033[1;37mADMINISTRAR CUENTAS SSH / TOKENS PREMIUM\n"
echo -ne " \033[1;32m [2] \033[1;31m=>> \033[1;37mGESTIONAR CUENTAS TÚNELES V2RAY / XRAY\n"
echo -ne " \033[1;32m [3] \033[1;31m=>> \033[1;37mAPERTURA MANUAL DE PUERTOS (SOCKS/SSL/SLOWDNS)\n"
echo -ne " \033[1;32m [4] \033[1;37m=>> \033[1;37mHERRAMIENTAS DE RED, TORRENT, REBOOT Y SEGURIDAD\n"
echo -ne " \033[1;32m [5] \033[1;35m=>> \033[1;35mACTUALIZAR PANEL E INSTALADORES CORE O.S\n"
echo -ne " \033[1;32m [6] \033[1;31m=>> \033[1;31mDESINSTALAR SCRIPT COMPLETAMENTE DEL VPS\n"
echo -ne " \033[1;32m [0] \033[1;31m=>> \033[1;41m SALIR DEL PANEL CONTROL \033[0m\n"
msg -bar

selection=$(selection_fun 6)
case ${selection} in
1) administrar_cuentas_sama ;;
2) gestionar_v2ray_sama ;;
3) protocolos_dinamicos_sama ;;
4) herramientas_avanzadas_sama ;;
5)
   msg -bar && echo -e " \e[1;36m[+] Sincronizando e instalando dependencias core...\e[0m"
   [[ ! -f /usr/local/bin/xray ]] && bash -c "$(curl -L https://github.com/XTLS/Xray-install/raw/main/install-release.sh)" @ install --beta >/dev/null 2>&1
   if wget -q --spider https://raw.githubusercontent.com/edusama79/VPS-SAMA/main/instalar.sh; then
      rm -rf /root/instalar.sh && wget -O /root/instalar.sh https://raw.githubusercontent.com/edusama79/VPS-SAMA/main/instalar.sh
      chmod +x /root/instalar.sh && exec bash /root/instalar.sh
   else echo -e " \e[1;32m[+] Entorno actualizado en vivo de forma local.\e[0m" && read -p " Enter..." ; fi ;;
6)
   msg -bar && echo -e " \e[1;31m🚨 ALERTA: Desinstalación integral.\e[0m"
   read -p " ¿Eliminar de raíz? (s/n): " confirm_des
   if [[ "$confirm_des" = "s" || "$confirm_des" = "S" ]]; then
      fuser -k 81/tcp >/dev/null 2>&1 && pkill -f api_puerto81.py >/dev/null 2>&1
      pkill -f monitor.sh >/dev/null 2>&1 && pkill -f PDirect.py >/dev/null 2>&1
      systemctl stop stunnel4 >/dev/null 2>&1 && pkill -f dns-server >/dev/null 2>&1
      systemctl stop xray >/dev/null 2>&1
      sed -i '/sama_api81/d' /etc/crontab && sed -i '/monitor_sama/d' /etc/crontab
      rm -rf /etc/VPS-SAMA /bin/menu /bin/sama /root/instalar.sh /usr/local/bin/xray /usr/local/etc/xray
      echo -e " \e[1;32m[+] Desinstalado de raíz.\e[0m" && exit 0
   fi ;;
0) exit 0 ;;
esac
/etc/VPS-SAMA/menu
