msg -bar
echo -e "      \033[1;37mIP VPS: \033[1;93m$(meu_ip)     \033[1;37mSISTEMA O.S: \033[1;96m$(os_system)"
echo -e "      \033[1;37mNÚCLEOS CPU: \033[1;32m$_core       \033[1;37mUSO RAM: \033[1;32m$_usor"
msg -bar

echo -ne " \033[1;32m [1] \033[1;31m=>> \033[1;37mADMINISTRAR CUENTAS SSH / TOKENS PREMIUM\n"
echo -ne " \033[1;32m [2] \033[1;31m=>> \033[1;37mGESTIONAR CUENTAS TÚNELES V2RAY / XRAY ——> $(check_status v2ray)\n"
echo -ne " \033[1;32m [3] \033[1;31m=>> \033[1;37mAPERTURA MANUAL DE PUERTOS (INTERRUPTORES PROTOCOLOS)\n"
echo -ne " \033[1;32m [4] \033[1;37m=>> \033[1;37mHERRAMIENTAS DE RED, TORRENT, REBOOT Y SEGURIDAD\n"
