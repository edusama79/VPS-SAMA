msg -bar

selection=$(selection_fun 6)
case ${selection} in
1) administrar_cuentas_sama ;;
2) gestionar_v2ray_sama ;;
3) protocolos_dinamicos_sama ;;
4) herramientas_avanzadas_sama ;;
5)
   msg -bar && echo -e " \e[1;36m[+] Sincronizando e instalando dependencias core...\e[0m"
   if wget -q --spider https://raw.githubusercontent.com/edusama79/VPS-SAMA/main/instalar.sh; then
      rm -rf /root/instalar.sh && wget -O /root/instalar.sh https://raw.githubusercontent.com/edusama79/VPS-SAMA/main/instalar.sh
      chmod +x /root/instalar.sh && exec bash /root/instalar.sh
   else echo -e " \e[1;32m[+] Entorno actualizado en vivo de forma local.\e[0m" && read -p " Enter..." ; fi ;;
6)
   msg -bar && echo -e " \e[1;31m🚨 ALERTA: Desinstalación integral.\e[0m"
   read -p " ¿Eliminar de raíz? (s/n): " confirm_des
   if [[ "$confirm_des" = "s" || "$confirm_des" = "S" ]]; then
      pkill -f PDirect.py >/dev/null 2>&1
      systemctl stop stunnel4 >/dev/null 2>&1
      systemctl stop xray >/dev/null 2>&1
      systemctl stop apache2 >/dev/null 2>&1
      sed -i '/limpieza_vencidos/d' /etc/crontab && sed -i '/reboot/d' /etc/crontab
      rm -rf /etc/VPS-SAMA /bin/menu /bin/sama /root/instalar.sh
      echo -e " \e[1;32m[+] Desinstalado de raíz.\e[0m" && exit 0
   fi ;;
0) exit 0 ;;
esac
/etc/VPS-SAMA/menu
