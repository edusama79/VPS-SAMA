#!/bin/bash
# =========================================================
#             SCRIPT CENTRAL: VPS-SAMA PREMIUM
# =========================================================
clear
clear
sudo sysctl -w net.ipv6.conf.all.disable_ipv6=1 >/dev/null 2>&1
sudo sysctl -w net.ipv6.conf.default.disable_ipv6=1 >/dev/null 2>&1
sudo sysctl -w net.ipv6.conf.lo.disable_ipv6=1 >/dev/null 2>&1
_hora=$(date +"%D-%H:%M:%S")

# COLORES
red=$(tput setaf 1)
gren=$(tput setaf 2)
yellow=$(tput setaf 3)

SCPdir="/etc/VPS-SAMA" && [[ ! -d ${SCPdir} ]] && mkdir -p ${SCPdir}
touch /etc/VPS-SAMA/usuarios.db

# Configuración inicial de la Clave Token por defecto si no existe
if [ ! -f "/etc/VPS-SAMA/token.key" ]; then
   echo "sama123" > /etc/VPS-SAMA/token.key
fi

# RENDIMIENTO DE MEMORIA Y PROCESADOR
_core=$(printf '%-1s' "$(grep -c cpu[0-9] /proc/stat)")
_usop=$(top -bn1 | sed -rn '3s/[^0-9]* ([0-9\.]+) .*/\1/p;4s/.*, ([0-9]+) .*/\1/p' | tr '\n' ' ')
ram1=$(free -h | grep -i mem | awk {'print $2'})
ram2=$(free -h | grep -i mem | awk {'print $4'})
ram3=$(free -h | grep -i mem | awk {'print $3'})
_usor=$(printf '%-8s' "$(free -m | awk 'NR==2{printf "%.2f%%", $3*100/$2 }')")

# Funciones de Interfaz Estética de Líneas
msg() {
   NEGRITO='\e[1m'
   SEMCOR='\e[0m'
   COLOR[0]='\033[1;37m' # Blanco
   COLOR[1]='\e[31m'     # Rojo
   COLOR[2]='\e[32m'     # Verde
   COLOR[3]='\e[33m'     # Amarillo
   COLOR[6]='\033[1;97m' # Cyan/Blanco Brillante
   
   case $1 in
   -ne) cor="${COLOR[1]}${NEGRITO}" && echo -ne "${cor}${2}${SEMCOR}" ;;
   -ama) cor="${COLOR[3]}${NEGRITO}" && echo -e "${cor}${2}${SEMCOR}" ;;
   -verm) cor="${COLOR[3]}${NEGRITO}[!] ${COLOR[1]}" && echo -e "${cor}${2}${SEMCOR}" ;;
   -azu) cor="${COLOR[6]}${NEGRITO}" && echo -e "${cor}${2}${SEMCOR}" ;;
   -verd) cor="${COLOR[2]}${NEGRITO}" && echo -e "${cor}${2}${SEMCOR}" ;;
   -bra) cor="${COLOR[0]}${SEMCOR}" && echo -e "${cor}${2}${SEMCOR}" ;;
   "-bar2" | "-bar") cor="${COLOR[1]}————————————————————————————————————————————————————" && echo -e "${SEMCOR}${cor}${SEMCOR}" ;;
   -tit) echo -e "\e[97m \033[1;41m| #-#-► 🐲 SCRIPT VPS-SAMA PREMIUM ◄-#-# | \033[0;37m" ;;
   esac
}

meu_ip() {
   if [[ -e /etc/VPS-SAMA/MEUIPvps ]]; then
      echo "$(cat /etc/VPS-SAMA/MEUIPvps)"
   else
      MEU_IP=$(curl -sS https://api.ipify.org || curl -sS https://ifconfig.me/ip || wget -qO- ipinfo.io/ip)
      echo "$MEU_IP" | tr -d '[:space:]' > /etc/VPS-SAMA/MEUIPvps
      echo "$MEU_IP"
   fi
}

os_system() {
   system=$(echo $(cat -n /etc/issue | grep 1 | cut -d' ' -f6,7,8 | sed 's/1//' | sed 's/      //'))
   echo $system | awk '{print $1, $2}'
}

selection_fun() {
   local selection="null"
   local range
   for ((i = 0; i <= $1; i++)); do range[$i]="$i "; done
   while [[ ! $(echo ${range[*]} | grep -w "$selection") ]]; do
      echo -ne "\033[1;37m ► Selecione una Opcion: " >&2
      read selection
      tput cuu1 >&2 && tput dl1 >&2
   done
   echo $selection
}

# =========================================================
# [1] ADMINISTRAR CUENTAS (NORMAL, HWID, TOKEN) + API APPS
# =========================================================
administrar_cuentas_sama() {
   clear
   msg -bar
   local CLAVE_TOKEN_ACTUAL=$(cat /etc/VPS-SAMA/token.key)
   
   echo -e "      \e[1;36m| #-#-► 🐲 ADMINISTRACIÓN DE CUENTAS ◄-#-# |\e[0m"
   msg -bar
   echo -e "      \033[1;37mClave Token Activa de Red: \033[1;93m$CLAVE_TOKEN_ACTUAL\e[0m"
   msg -bar
   echo -ne " \033[1;32m [1] \033[1;31m=>> \033[1;37mNORMAL (Usuario y Contraseña tradicional)\n"
   echo -ne " \033[1;32m [2] \033[1;31m=>> \033[1;37mHWID   (Bloqueo por ID único de celular)\n"
   echo -ne " \033[1;32m [3] \033[1;37mTOKEN  (Crear ingresando Token manual + Dueño)\n"
   echo -ne " \033[1;32m [4] \033[1;31m=>> \033[1;37mREMOVER USUARIO O TOKEN DEL SISTEMA\n"
   echo -ne " \033[1;32m [5] \033[1;31m=>> \033[1;37mLISTAR TODAS LAS CUENTAS REGISTRADAS\n"
   echo -ne " \033[1;32m [6] \033[1;31m=>> \033[1;37mEDITAR / CAMBIAR LA CLAVE TOKEN FIJA\n"
   echo -ne " \033[1;32m [0] \033[1;31m=>> \033[1;41m VOLVER AL MENÚ CENTRAL \033[0m\n"
   msg -bar
   
   local op_db=$(selection_fun 6)
   case $op_db in
   1)
      msg -bar
      read -p " Nombre de usuario: " user
      read -p " Contraseña: " pass
      read -p " Días de duración: " dias
      useradd -M -s /bin/false -e "$(date -d "$dias days" +"%Y-%m-%d")" $user
      echo "$user:$pass" | chpasswd
      fecha_venc=$(date -d "$dias days" +"%d/%m/%Y")
      echo "$user|NORMAL|$pass|$fecha_venc" >> /etc/VPS-SAMA/usuarios.db
      echo -e "\e[1;32m\n [+] Cuenta Normal '$user' creada hasta el $fecha_venc\e[0m"
      read -p " Presione Enter para continuar..."
      ;;
   2)
      msg -bar
      read -p " Nombre de usuario: " user
      read -p " Pegue el HWID / ID del dispositivo: " hwid
      read -p " Días de duración: " dias
      useradd -M -s /bin/false -e "$(date -d "$dias days" +"%Y-%m-%d")" $user
      echo "$user:hwidsama123" | chpasswd
      fecha_venc=$(date -d "$dias days" +"%d/%m/%Y")
      echo "$user|HWID|$hwid|$fecha_venc" >> /etc/VPS-SAMA/usuarios.db
      echo -e "\e[1;32m\n [+] Cuenta HWID vinculada con éxito hasta el $fecha_venc\e[0m"
      read -p " Presione Enter para continuar..."
      ;;
   3)
      msg -bar
      read -p " Nombre del Cliente (Para saber de quién es): " cliente_nom
      read -p " Ingrese o pegue el TOKEN manual (Usuario): " token_manual
      read -p " Días de duración para este Token: " dias
      
      local clave_uni=$(cat /etc/VPS-SAMA/token.key)
      cliente_nom=$(echo "$cliente_nom" | sed 's/ /_/g')
      [[ -z "$cliente_nom" ]] && cliente_nom="Sin_Nombre"

      if [[ -z "$token_manual" || -z "$dias" ]]; then
         echo -e "\e[1;31m\n [-] Error: Ningún campo puede quedar vacío.\e[0m"
         read -p " Presione Enter para continuar..."
         return 0
      fi
      
      useradd -M -s /bin/false -e "$(date -d "$dias days" +"%Y-%m-%d")" $token_manual
      echo "$token_manual:$clave_uni" | chpasswd
      fecha_venc=$(date -d "$dias days" +"%d/%m/%Y")
      
      echo "$token_manual|TOKEN|$clave_uni|$fecha_venc|$cliente_nom" >> /etc/VPS-SAMA/usuarios.db
      echo -e "\e[1;32m\n [+] ¡TOKEN REGISTRADO CON ÉXITO! \e[0m"
      echo -e "     \e[1;37mDueño / Cliente:\e[1;35m $cliente_nom \e[0m"
      echo -e "     \e[1;37mUsuario (Token):\e[1;36m $token_manual \e[0m"
      echo -e "     \e[1;37mContraseña Fija:\e[1;33m $clave_uni \e[0m"
      echo -e "     \e[1;37mVálido hasta el:\e[1;32m $fecha_venc \e[0m"
      read -p " Presione Enter para continuar..."
      ;;
   4)
      msg -bar
      read -p " Ingrese el Usuario o Token a eliminar: " user
      userdel -f $user
      sed -i "/^$user|/d" /etc/VPS-SAMA/usuarios.db
      echo -e "\e[1;31m[-] Eliminado por completo de la base de datos y del VPS.\e[0m"
      read -p " Presione Enter para continuar..."
      ;;
   5)
      clear
      echo -e "\e[1;36m┌────────────────────────────────────────────────────────┐\e[0m"
      echo -e "\e[1;36m│             BASE DE DATOS COMPLETA VPS-SAMA            │\e[0m"
      echo -e "\e[1;36m└────────────────────────────────────────────────────────┘\e[0m"
      printf " \e[1;33m%-16s %-8s %-12s %-12s %-12s\e[0m\n" "USUARIO/TOKEN" "TIPO" "CLAVE" "VENCIMIENTO" "DUEÑO"
      echo " ————————————————————————————————————————————————————"
      if [ -f /etc/VPS-SAMA/usuarios.db ]; then
          while IFS='|' read -r u t c v n; do
              [[ -z "$n" ]] && n="—"
              printf " %-16s %-8s %-12s %-12s %-12s\n" "$u" "$t" "$c" "$v" "$n"
          done < /etc/VPS-SAMA/usuarios.db
      fi
      echo " ————————————————————————————————————————————————————"
      read -p " Presione Enter para continuar..."
      ;;
   6)
      msg -bar
      read -p " Ingrese la NUEVA Clave Fija para los Tokens: " nueva_key
      if [ ! -z "$nueva_key" ]; then
         echo "$nueva_key" > /etc/VPS-SAMA/token.key
         echo -e "\e[1;32m\n [+] Clave Universal actualizada a: $nueva_key\e[0m"
      else
         echo -e "\e[1;31m\n [-] Cancelado. La clave no puede estar en blanco.\e[0m"
      fi
      read -p " Presione Enter para continuar..."
      ;;
   *) return 0 ;;
   esac
}

# =========================================================
#             INTERFAZ GRÁFICA PRINCIPAL (TERMINAL)
# =========================================================
clear
msg -bar
msg -tit
msg -bar
title=$(cat ${SCPdir}/message.txt 2>/dev/null || echo "VPS-SAMA PREMIUM")
echo -e "      \e[1;36mSlogan / Marca: $title\e[0m"
msg -bar
echo -e "      \033[1;37mIP VPS: \033[1;93m$(meu_ip)     \033[1;37mSISTEMA O.S: \033[1;96m$(os_system)"
echo -e "      \033[1;37mNÚCLEOS CPU: \033[1;32m$_core       \033[1;37mUSO RAM: \033[1;32m$_usor"
msg -bar

echo -ne " \033[1;32m [1] \033[1;31m=>> \033[1;37mADMINISTRAR CUENTAS (NORMAL / HWID / TOKEN)\n"
echo -ne " \033[1;32m [2] \033[1;31m=>> \033[1;37mINSTALADORES DE PROTOCOLOS Y TÚNELES\n"
echo -ne " \033[1;32m [3] \033[1;31m=>> \033[1;37mHERRAMIENTAS DE RED, PUERTOS Y OPTIMIZACIÓN BBR\n"
echo -ne " \033[1;32m [4] \033[1;37m=>> \033[1;37mMONITOR DE PROCESOS EN TIEMPO REAL (HTOP)\n"
echo -ne " \033[1;32m [5] \033[1;31m=>> \033[1;35mACTUALIZAR PANEL COMPLETO (ONLINE DESDE GITHUB)\n"
echo -ne " \033[1;32m [6] \033[1;31m=>> \033[1;31mDESINSTALAR SCRIPT COMPLETAMENTE DEL VPS\n"
echo -ne " \033[1;32m [0] \033[1;31m=>> \033[1;41m SALIR DEL PANEL CONTROL \033[0m\n"
msg -bar

selection=$(selection_fun 6)
case ${selection} in
1) administrar_cuentas_sama ;;
2) 
   clear
   msg -bar
   echo -e "         \e[1;36m⚙️ SUB-MENÚ INTERACTIVO DE PROTOCOLOS ⚙️\e[0m"
   msg -bar
   echo -e "  \e[1;32m[1]\e[1;37m > Configurar Proxy SOCKS PYTHON / WEBSOCKET"
   echo -e "  \e[1;32m[2]\e[1;37m > Configurar Servidor SSL / TLS (STUNNEL4)"
   echo -e "  \e[1;32m[3]\e[1;37m > Configurar Servidor SLOW DNS (Método Sin Saldo)"
   echo -e "  \e[1;32m[0]\e[1;37m > Cancelar y Volver al Menú Central"
   msg -bar
   read -p " Seleccione una opción: " sub_op
   if [ "$sub_op" = "1" ]; then bash /etc/VPS-SAMA/protocolos/sockspy.sh; fi
   if [ "$sub_op" = "2" ]; then bash /etc/VPS-SAMA/protocolos/ssl.sh; fi
   if [ "$sub_op" = "3" ]; then bash /etc/VPS-SAMA/protocolos/slowdns.sh; fi
   ;;
3) 
   clear
   msg -bar
   echo -e "         \e[1;36m⚙️ SUB-MENÚ DE HERRAMIENTAS Y AJUSTES RED ⚙️\e[0m"
   msg -bar
   echo -e "  \e[1;32m[1]\e[1;37m > Ver Lista de Puertos Activos (MONITOR LIST)"
   echo -e "  \e[1;32m[2]\e[1;37m > Optimizar Núcleo Linux y Activar Acelerador TCP BBR"
   echo -e "  \e[1;32m[0]\e[1;37m > Cancelar y Volver al Menú Central"
   msg -bar
   read -p " Seleccione una opción: " sub_her
   if [ "$sub_her" = "1" ]; then bash /etc/VPS-SAMA/herramientas/ports.sh; fi
   if [ "$sub_her" = "2" ]; then bash /etc/VPS-SAMA/herramientas/tcp.sh; fi
   ;;
4) sudo htop ;;
5)
   # ACTUALIZAR AUTOMÁTICO DESDE EL MENÚ PRINCIPAL
   msg -bar
   echo -e " \e[1;36m[+] Conectando con el servidor de GitHub de edusama79...\e[0m"
   sleep 1
   if wget -q --spider https://raw.githubusercontent.com/edusama79/VPS-SAMA/main/instalar.sh; then
      echo -e " \e[1;32m[+] ¡Actualización encontrada! Bajando paquetes nuevos...\e[0m"
      rm -rf /root/instalar.sh
      wget -O /root/instalar.sh https://raw.githubusercontent.com/edusama79/VPS-SAMA/main/instalar.sh
      chmod +x /root/instalar.sh
      echo -e " \e[1;32m[+] Ejecutando instalación de fondo...\e[0m"
      sleep 1
      exec bash /root/instalar.sh
   else
      echo -e " \e[1;31m[-] Error: No se pudo conectar a GitHub.\e[0m"
      read -p " Presione Enter para continuar..."
   fi
   ;;
6)
   # DESINSTALADOR INTEGRAL
   msg -bar
   echo -e " \e[1;31m🚨 ALERTA: Esto eliminará por completo el script y parará las APIs.\e[0m"
   read -p " ¿Está seguro de que desea desinstalar VPS-SAMA? (s/n): " confirm_des
   if [[ "$confirm_des" = "s" || "$confirm_des" = "S" ]]; then
      echo -e " \e[1;31m[-] Deteniendo APIs del puerto 81 y monitores de fondo...\e[0m"
      fuser -k 81/tcp >/dev/null 2>&1
      pkill -f api_puerto81.py >/dev/null 2>&1
      pkill -f monitor.sh >/dev/null 2>&1
      pkill -f PDirect.py >/dev/null 2>&1
      systemctl stop stunnel4 >/dev/null 2>&1
      pkill -f dns-server >/dev/null 2>&1
      
      echo -e " \e[1;31m[-] Limpiando automatizaciones en el Crontab...\e[0m"
      sed -i '/sama_api81/d' /etc/crontab
      sed -i '/monitor_sama/d' /etc/crontab
      
      echo -e " \e[1;31m[-] Eliminando archivos, carpetas y accesos directos...\e[0m"
      rm -rf /etc/VPS-SAMA
      rm -rf /bin/menu /bin/sama /root/instalar.sh
      
      echo -e " \e[1;32m[+] ¡VPS-SAMA ha sido completamente desinstalado de su VPS!\e[0m"
      exit 0
   else
      echo -e " \e[1;32m[+] Desinstalación cancelada.\e[0m"
      read -p " Presione Enter para continuar..."
   fi
   ;;
0) exit 0 ;;
esac

# Retorno automático al bucle del panel
/etc/VPS-SAMA/menu
