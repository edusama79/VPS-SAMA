#!/bin/bash
# =========================================================
#             SCRIPT CENTRAL: SCRIPT VPS-MX ORIGINAL
# =========================================================
clear
clear
sudo sysctl -w net.ipv6.conf.all.disable_ipv6=1 >/dev/null 2>&1
sudo sysctl -w net.ipv6.conf.default.disable_ipv6=1 >/dev/null 2>&1
sudo sysctl -w net.ipv6.conf.lo.disable_ipv6=1 >/dev/null 2>&1

# COLORES
red=$(tput setaf 1)
gren=$(tput setaf 2)
yellow=$(tput setaf 3)

SCPdir="/etc/VPS-SAMA" && [[ ! -d ${SCPdir} ]] && mkdir -p ${SCPdir}
touch /etc/VPS-SAMA/usuarios.db
touch /etc/VPS-SAMA/v2ray_usuarios.db

# Configuración inicial de la Clave Token y Slogan si no existen
[[ ! -f "/etc/VPS-SAMA/token.key" ]] && echo "sama123" > /etc/VPS-SAMA/token.key
[[ ! -f "/etc/VPS-SAMA/message.txt" ]] && echo "LATAM VPS PREMIUM" > /etc/VPS-SAMA/message.txt

# RENDIMIENTO DE MEMORIA Y PROCESADOR (ESTILO VPS-MX)
_core=$(printf '%-1s' "$(grep -c cpu[0-9] /proc/stat)")
_usop=$(top -bn1 | sed -rn '3s/[^0-9]* ([0-9\.]+) .*/\1/p;4s/.*, ([0-9]+) .*/\1/p' | tr '\n' ' ')
_usor=$(printf '%-8s' "$(free -m | awk 'NR==2{printf "%.2f%%", $3*100/$2 }')")

msg() {
   NEGRITO='\e[1m' && SEMCOR='\e[0m'
   COLOR[0]='\033[1;37m' # Blanco
   COLOR[1]='\e[31m'     # Rojo
   COLOR[2]='\e[32m'     # Verde
   COLOR[3]='\e[33m'     # Amarillo
   COLOR[6]='\033[1;97m' # Cyan Brillante
   case $1 in
   -ne) cor="${COLOR[1]}${NEGRITO}" && echo -ne "${cor}${2}${SEMCOR}" ;;
   -ama) cor="${COLOR[3]}${NEGRITO}" && echo -e "${cor}${2}${SEMCOR}" ;;
   -azu) cor="${COLOR[6]}${NEGRITO}" && echo -e "${cor}${2}${SEMCOR}" ;;
   -verd) cor="${COLOR[2]}${NEGRITO}" && echo -e "${cor}${2}${SEMCOR}" ;;
   "-bar2" | "-bar") cor="${COLOR[1]}————————————————————————————————————————————————————" && echo -e "${SEMCOR}${cor}${SEMCOR}" ;;
   -tit) echo -e "\e[97m \033[1;41m| #-#-► 🐲 SCRIPT VPS-MX ORIGINAL MOD ◄-#-# | \033[0;37m" ;;
   esac
}

meu_ip() {
   if [[ -e /etc/VPS-SAMA/MEUIPvps ]]; then
      echo "$(cat /etc/VPS-SAMA/MEUIPvps)"
   else
      MEU_IP=$(curl -sS https://api.ipify.org || curl -sS https://ifconfig.me/ip || wget -qO- ipinfo.io/ip)
      echo "$MEU_IP" | tr -d '[:space:]' > /etc/VPS-SAMA/MEUIPvps
      echo "$MEU_IP"
   fi
}

os_system() {
   system=$(echo $(cat -n /etc/issue | grep 1 | cut -d' ' -f6,7,8 | sed 's/1//' | sed 's/      //'))
   echo $system | awk '{print $1, $2}'
}

selection_fun() {
   local selection="null" && local range
   for ((i = 0; i <= $1; i++)); do range[$i]="$i "; done
   while [[ ! $(echo ${range[*]} | grep -w "$selection") ]]; do
      echo -ne "\033[1;37m ► Selecione una Opcion: " >&2
      read selection
      tput cuu1 >&2 && tput dl1 >&2
   done
   echo $selection
}

# =========================================================
#  API EN PUERTO 81 PARA CONSULTA DESDE LA APLICACIÓN
# =========================================================
iniciar_api_web_vencimientos() {
   # Instalar dependencias si faltan
   if ! command -v nc &> /dev/null; then apt-get install netcat-openbsd -y >/dev/null 2>&1; fi
   
   # Detener procesos viejos en el puerto 81
   fuser -k 81/tcp >/dev/null 2>&1
   
   # Crear el script de la API que lee la DB e interactúa con la app
   cat << 'EOF' > /etc/VPS-SAMA/api_vencimientos.sh
#!/bin/bash
while true; do
   # Escuchar peticiones en el puerto 81 y procesar el nombre de usuario enviado
   printf "HTTP/1.1 200 OK\r\nContent-Type: text/plain\r\n\r\n" > /tmp/resp_http
   
   req=$(nc -l -p 81 -q 1)
   user_req=$(echo "$req" | head -n 1 | awk '{print $2}' | tr -d '/')
   
   if [[ ! -z "$user_req" ]]; then
      # Buscar los días restantes del usuario en la base de datos
      info_user=$(grep -w "^$user_req" /etc/VPS-SAMA/usuarios.db)
      if [[ ! -z "$info_user" ]]; then
         venc=$(echo "$info_user" | cut -d'|' -f4)
         # Calcular los días que le quedan de forma exacta
         diff_sec=$(( $(date -d "$(echo $venc | awk -F/ '{print $3"-"$2"-"$1}')" +%s) - $(date +%s) ))
         dias_rest=$(( diff_sec / 86400 + 1 ))
         if [ $dias_rest -lt 0 ]; then dias_rest=0; fi
         echo "$dias_rest" >> /tmp/resp_http
      else
         echo "not_found" >> /tmp/resp_http
      fi
   fi
   cat /tmp/resp_http
done
EOF
   chmod +x /etc/VPS-SAMA/api_vencimientos.sh
   screen -dmS api_vencidos bash /etc/VPS-SAMA/api_vencimientos.sh
}

# =========================================================
# [1] GESTIÓN DE USUARIOS CALCADA DE LATAM VPS
# =========================================================
administrar_cuentas_sama() {
   clear && msg -bar
   local CLAVE_TOKEN_ACTUAL=$(cat /etc/VPS-SAMA/token.key)
   echo -e " \033[1;31m| #-#-► \033[1;37mPANEL GESTION DE USUARIOS SSH/TOKEN\033[1;31m ◄-#-# |"
   msg -bar
   echo -e "  \033[1;37mClave Token Activa de Red: \033[1;93m$CLAVE_TOKEN_ACTUAL\e[0m"
   msg -bar
   echo -ne " \033[1;32m [1] \033[1;31m=>> \033[1;37mCREAR USUARIO SSH (NORMAL)\n"
   echo -ne " \033[1;32m [2] \033[1;31m=>> \033[1;37mCREAR USUARIO SSH (HWID)\n"
   echo -ne " \033[1;32m [3] \033[1;31m=>> \033[1;37mCREAR REGISTRO DE TOKEN MANUAL\n"
   echo -ne " \033[1;32m [4] \033[1;31m=>> \033[1;37mELIMINAR USUARIO O TOKEN (LISTADO)\n"
   echo -ne " \033[1;32m [5] \033[1;31m=>> \033[1;37mVER LISTADO DE USUARIOS DETALLADO\n"
   echo -ne " \033[1;32m [6] \033[1;31m=>> \033[1;37mCAMBIAR CONTRASENA TOKEN GLOBAL\n"
   echo -ne " \033[1;32m [0] \033[1;31m=>> \033[1;41m VOLVER AL MENU ANTERIOR \033[0m\n"
   msg -bar
   
   local op_db=$(selection_fun 6)
   case $op_db in
   1)
      msg -bar
      while true; do
         echo -ne " \033[1;32m[*] \033[1;31m=>> \033[1;37mNombre de usuario (Max 16): " && read user
         [[ ${#user} -le 16 && ! -z "$user" ]] && break || echo -e " \e[1;31m     [!] Usuario invalido.\e[0m"
      done
      while true; do
         echo -ne " \033[1;32m[*] \033[1;31m=>> \033[1;37mContrasena de usuario (Max 16): " && read pass
         [[ ${#pass} -le 16 && ! -z "$pass" ]] && break || echo -e " \e[1;31m     [!] Contrasena invalida.\e[0m"
      done
      echo -ne " \033[1;32m[*] \033[1;31m=>> \033[1;37mDias de duracion: " && read dias
      useradd -M -s /bin/false -e "$(date -d "$dias days" +"%Y-%m-%d")" $user && echo "$user:$pass" | chpasswd
      echo "$user|NORMAL|$pass|$(date -d "$dias days" +"%d/%m/%Y")" >> /etc/VPS-SAMA/usuarios.db
      echo -e "\e[1;32m\n [+] Usuario registrado con exito.\e[0m" && read -p " Presione Enter para continuar..." ;;
   2)
      msg -bar
      while true; do
         echo -ne " \033[1;32m[*] \033[1;31m=>> \033[1;37mNombre de usuario (Max 16): " && read user
         [[ ${#user} -le 16 && ! -z "$user" ]] && break || echo -e " \e[1;31m     [!] Usuario invalido.\e[0m"
      done
      echo -ne " \033[1;32m[*] \033[1;31m=>> \033[1;37mPegue el codigo HWID del celular: " && read hwid
      echo -ne " \033[1;32m[*] \033[1;31m=>> \033[1;37mDias de duracion: " && read dias
      useradd -M -s /bin/false -e "$(date -d "$dias days" +"%Y-%m-%d")" $user && echo "$user:hwidsama123" | chpasswd
      echo "$user|HWID|$hwid|$(date -d "$dias days" +"%d/%m/%Y")" >> /etc/VPS-SAMA/usuarios.db
      echo -e "\e[1;32m\n [+] Usuario HWID registrado con exito.\e[0m" && read -p " Presione Enter para continuar..." ;;
   3)
      msg -bar
      echo -ne " \033[1;32m[*] \033[1;31m=>> \033[1;37mNombre del Cliente / Dueno: " && read cliente_nom
      while true; do
         echo -ne " \033[1;32m[*] \033[1;31m=>> \033[1;37mIngrese o pegue el TOKEN manual (Max 16): " && read token_manual
         [[ ${#token_manual} -le 16 && ! -z "$token_manual" ]] && break || echo -e " \e[1;31m     [!] Token invalido.\e[0m"
      done
      echo -ne " \033[1;32m[*] \033[1;31m=>> \033[1;37mDias de duracion: " && read dias
      local clave_uni=$(cat /etc/VPS-SAMA/token.key)
      cliente_nom=$(echo "$cliente_nom" | sed 's/ /_/g') && [[ -z "$cliente_nom" ]] && cliente_nom="Sin_Nombre"
      useradd -M -s /bin/false -e "$(date -d "$dias days" +"%Y-%m-%d")" $token_manual && echo "$token_manual:$clave_uni" | chpasswd
      echo "$token_manual|TOKEN|$clave_uni|$(date -d "$dias days" +"%d/%m/%Y")|$cliente_nom" >> /etc/VPS-SAMA/usuarios.db
      echo -e "\e[1;32m\n [+] ¡TOKEN REGISTRADO CON EXITO EN LA RED!\e[0m" && read -p " Presione Enter para continuar..." ;;
   4)
      clear && msg -bar && echo -e "         \e[1;31m🚨 GESTOR DE BAJAS DE CUENTAS / TOKENS 🚨\e[0m" && msg -bar
      if [[ ! -s /etc/VPS-SAMA/usuarios.db ]]; then echo -e " \e[1;31m[-] No hay usuarios registrados.\e[0m" && msg -bar && read -p " Presione Enter para continuar..." && return 0; fi
      local i=1 && declare -A lista_users
      while IFS='|' read -r u t c v n; do
         printf "  \e[1;32m[%02d]\e[1;31m => Gram \e[1;37m%-15s \e[1;33m%-8s \e[1;35m(Dueno: %s)\e[0m\n" "$i" "$u" "$t" "$n"
         lista_users[$i]="$u" && i=$((i+1))
      done < /etc/VPS-SAMA/usuarios.db
      echo " ————————————————————————————————————————————————————"
      echo -ne " \033[1;32m[*] \033[1;31m=>> \033[1;37mSeleccione el numero a dar de baja: " && read num_elim
      local usuario_seleccionado="${lista_users[$num_elim]}"
      if [[ -z "$usuario_seleccionado" ]]; then echo -e "\e[1;31m\n [-] Seleccion invalida.\e[0m" && read -p " Presione Enter para continuar..." && return 0; fi
      msg -bar && echo -ne " \033[1;32m[*] \033[1;31m=>> \033[1;33m¿Seguro de eliminar a $usuario_seleccionado? (s/n): \033[0m" && read confirm_user
      if [[ "$confirm_user" = "s" || "$confirm_user" = "S" ]]; then
         userdel -f "$usuario_seleccionado" >/dev/null 2>&1
         sed -i "/^$usuario_seleccionado|/d" /etc/VPS-SAMA/usuarios.db
         echo -e "\e[1;32m\n [+] Removido correctamente.\e[0m"
      fi
      read -p " Presione Enter para continuar..." ;;
   5)
      clear && echo -e "\e[1;36m┌────────────────────────────────────────────────────────┐\e[0m"
      printf " \e[1;33m%-16s %-8s %-12s %-12s %-12s\e[0m\n" "USUARIO/TOKEN" "TIPO" "CLAVE" "VENCIMIENTO" "DUENO"
      echo " ————————————————————————————————————————————————————"
      while IFS='|' read -r u t c v n; do [[ -z "$n" ]] && n="—"; printf " %-16s %-8s %-12s %-12s %-12s\n" "$u" "$t" "$c" "$v" "$n"; done < /etc/VPS-SAMA/usuarios.db
      echo " ————————————————————————————————————————————————————" && read -p " Presione Enter para continuar..." ;;
   6)
      msg -bar && echo -ne " \033[1;32m[*] \033[1;31m=>> \033[1;37mIngrese la NUEVA Contrasena Token Global (Max 16): " && read nueva_key
      [[ ! -z "$nueva_key" && ${#nueva_key} -le 16 ]] && echo "$nueva_key" > /etc/VPS-SAMA/token.key && echo -e "\e[1;32m\n [+] Contrasena actualizada.\e[0m" || echo -e "\e[1;31m[!] Error en el largo.\e[0m"
      read -p " Presione Enter para continuar..." ;;
   esac
}

# =========================================================
# [2] PROTOCOLOS Y PUERTOS (TAL CUAL SCRIPT VPS-MX)
# =========================================================
abrir_protocolos_mx() {
   clear && msg -bar
   echo -e "         \e[1;36m⚙️ INSTALADORES Y PROTOCOLO DEL VPS-MX ⚙️\e[0m"
   msg -bar
   echo -e "  \e[1;32m[1]\e[1;37m > Configurar / Abrir Proxy SOCKS WEBSOCKET"
   echo -e "  \e[1;32m[2]\e[1;37m > Configurar / Abrir Servidor SSL (STUNNEL4)"
   echo -e "  \e[1;32m[3]\e[1;37m > Configurar / Abrir Servidor SLOW DNS"
   echo -e "  \e[1;32m[4]\e[1;37m > Configurar / Abrir Servidor V2RAY (WS)"
   echo -e "  \e[1;32m[0]\e[1;37m > Volver al Menú Central"
   msg -bar
   read -p " Seleccione una opción: " sub_op
   
   if [[ "$sub_op" = "1" ]]; then
      msg -bar
      echo -ne " \033[1;32m[*] \033[1;31m=>> \033[1;37mElija el PUERTO manual para abrir WebSocket: " && read p_ws
      if [[ ! -z "$p_ws" ]]; then
         pkill -f PDirect.py >/dev/null 2>&1
         # Usar el archivo nativo de la carpeta protocolos
         screen -dmS ws_sama python3 /etc/VPS-SAMA/protocolos/PDirect.py $p_ws
         echo -e " \e[1;32m[+] WebSocket abierto en el puerto $p_ws\e[0m"
      fi
      read -p " Enter..."
   fi
   
   if [[ "$sub_op" = "2" ]]; then
      msg -bar
      echo -ne " \033[1;32m[*] \033[1;31m=>> \033[1;37mElija el PUERTO manual para abrir SSL: " && read p_ssl
      if [[ ! -z "$p_ssl" ]]; then
         systemctl stop stunnel4 >/dev/null 2>&1
         cat <<EOF > /etc/stunnel/stunnel.conf
pid = /var/run/stunnel4.pid
cert = /etc/stunnel/stunnel.pem
[ssh]
accept = ${p_ssl}
connect = 127.0.0.1:22
EOF
         systemctl start stunnel4 >/dev/null 2>&1
         echo -e " \e[1;32m[+] SSL levantado en el puerto $p_ssl\e[0m"
      fi
      read -p " Enter..."
   fi
   
   if [[ "$sub_op" = "3" ]]; then
      bash /etc/VPS-SAMA/protocolos/slowdns.sh
   fi

   if [[ "$sub_op" = "4" ]]; then
      msg -bar
      echo -ne " \033[1;32m[*] \033[1;31m=>> \033[1;37mElija el PUERTO manual para abrir V2Ray WS: " && read p_v2
      if [[ ! -z "$p_v2" ]]; then
         # Escribir la configuración estándar de Xray para el puerto dinámico elegido
         mkdir -p /usr/local/etc/xray
         cat <<EOF > /usr/local/etc/xray/config.json
{
  "inbounds": [{
    "port": ${p_v2},
    "protocol": "vless",
    "settings": { "clients": [], "decryption": "none" },
    "streamSettings": { "network": "ws", "wsSettings": { "path": "/vps-sama" } }
  }],
  "outbounds": [{ "protocol": "freedom" }]
}
EOF
         pkill -f "xray" >/dev/null 2>&1
         screen -dmS xray_mx /usr/local/bin/xray -config /usr/local/etc/xray/config.json
         echo -e " \e[1;32m[+] V2Ray corriendo libre en el puerto $p_v2\e[0m"
      fi
      read -p " Enter..."
   fi
}

# =========================================================
# [3] HERRAMIENTAS COMPLETAS (HEREDADAS DE VPS-MX)
# =========================================================
herramientas_mx() {
   clear && msg -bar
   echo -e "         \e[1;36m⚙️ GESTOR DE HERRAMIENTAS VPS-MX ⚙️\e[0m"
   msg -bar
   echo -e "  \e[1;32m[1]\e[1;37m > Ver Puertos Activos y Conexiones"
   echo -e "  \e[1;32m[2]\e[1;37m > Activar Acelerador TCP BBR"
   echo -e "  \e[1;32m[3]\e[1;37m > Regla Anti-Torrent / Bloqueo P2P"
   echo -e "  \e[1;32m[4]\e[1;37m > Programar Limpieza Nocturna de RAM (3 AM)"
   echo -e "  \e[1;32m[0]\e[1;37m > Volver al Menú Principal"
   msg -bar
   read -p " Seleccione una opción: " sub_her
   
   case $sub_her in
   1) bash /etc/VPS-SAMA/herramientas/ports.sh ;;
   2) bash /etc/VPS-SAMA/herramientas/tcp.sh ;;
   3)
      iptables -A FORWARD -m string --algo bm --string "torrent" -j DROP
      echo -e "\e[1;32m[+] Filtro Anti-Torrent activado.\e[0m" && read -p " Enter..." ;;
   4)
      sed -i '/reboot/d' /etc/crontab
      echo "0 3 * * * root /sbin/reboot" >> /etc/crontab
      echo -e "\e[1;32m[+] Tarea programada en Crontab con éxito.\e[0m" && read -p " Enter..." ;;
   esac
}

# =========================================================
#             INTERFAZ GRÁFICA PRINCIPAL (TERMINAL)
# =========================================================
# Asegurar el inicio automático de la API en el puerto 81 al cargar el menú
if ! screen -list | grep -q "api_vencidos"; then
   iniciar_api_web_vencimientos
fi

clear && msg -bar && msg -tit && msg -bar
title=$(cat ${SCPdir}/message.txt)
echo -e "      \e[1;36mSlogan Principal: $title\e[0m"
msg -bar
echo -e "      \033[1;37mIP VPS: \033[1;93m$(meu_ip)     \033[1;37mSISTEMA O.S: \033[1;96m$(os_system)"
echo -e "      \033[1;37mNÚCLEOS CPU: \033[1;32m$_core       \033[1;37mUSO RAM: \033[1;32m$_usor"
msg -bar

echo -ne " \033[1;32m [1] \033[1;31m=>> \033[1;37mADMINISTRAR CUENTAS USUARIOS (ESTILO LATAM)\n"
echo -ne " \033[1;32m [2] \033[1;31m=>> \033[1;37mABRIR PROTOCOLOS Y PUERTOS DINÁMICOS (ESTILO VPS-MX)\n"
echo -ne " \033[1;32m [3] \033[1;31m=>> \033[1;37mHERRAMIENTAS DE RED, TORRENT Y SEGURIDAD (VPS-MX)\n"
echo -ne " \033[1;32m [4] \033[1;35m=>> \033[1;35mACTUALIZAR SCRIPT DESDE TU GITHUB\n"
echo -ne " \033[1;32m [5] \033[1;31m=>> \033[1;31mDESINSTALAR TODO EL SCRIPT DEL SERVIDOR\n"
echo -ne " \033[1;32m [0] \033[1;31m=>> \033[1;41m SALIR DEL PANEL DE GESTIÓN \033[0m\n"
msg -bar

selection=$(selection_fun 5)
case ${selection} in
1) administrar_cuentas_sama ;;
2) abrir_protocolos_mx ;;
3) herramientas_mx ;;
4)
   msg -bar && echo -e " \e[1;36m[+] Bajando última versión limpia de tu GitHub...\e[0m"
   sleep 1
   wget -O /etc/VPS-SAMA/menu https://raw.githubusercontent.com/edusama79/VPS-SAMA/main/menu
   chmod +x /etc/VPS-SAMA/menu
   echo -e " \e[1;32m[+] ¡Panel sincronizado de forma instantánea!\e[0m"
   sleep 1
   exec bash /etc/VPS-SAMA/menu ;;
5)
   read -p " ¿Querés borrar todo el script del VPS? (s/n): " confirm_des
   if [[ "$confirm_des" = "s" || "$confirm_des" = "S" ]]; then
      fuser -k 81/tcp >/dev/null 2>&1
      rm -rf /etc/VPS-SAMA /bin/menu /bin/sama
      echo -e " \e[1;32m[+] Removido del sistema.\e[0m" && exit 0
   fi ;;
0) exit 0 ;;
esac
/etc/VPS-SAMA/menu
