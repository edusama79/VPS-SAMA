#!/bin/bash
# =========================================================
#             SCRIPT CENTRAL: VPS-SAMA PREMIUM
# =========================================================
clear
clear
sudo sysctl -w net.ipv6.conf.all.disable_ipv6=1 >/dev/null 2>&1
sudo sysctl -w net.ipv6.conf.default.disable_ipv6=1 >/dev/null 2>&1
sudo sysctl -w net.ipv6.conf.lo.disable_ipv6=1 >/dev/null 2>&1
_hora=$(date +"%D-%H:%M:%S")

# COLORES
red=$(tput setaf 1)
gren=$(tput setaf 2)
yellow=$(tput setaf 3)

SCPdir="/etc/VPS-SAMA" && [[ ! -d ${SCPdir} ]] && mkdir -p ${SCPdir}
touch /etc/VPS-SAMA/usuarios.db

# ConfiguraciГіn inicial de la Clave Token por defecto si no existe
if [ ! -f "/etc/VPS-SAMA/token.key" ]; then
   echo "sama123" > /etc/VPS-SAMA/token.key
fi

# RENDIMIENTO DE MEMORIA Y PROCESADOR
_core=$(printf '%-1s' "$(grep -c cpu[0-9] /proc/stat)")
_usop=$(top -bn1 | sed -rn '3s/[^0-9]* ([0-9\.]+) .*/\1/p;4s/.*, ([0-9]+) .*/\1/p' | tr '\n' ' ')
ram1=$(free -h | grep -i mem | awk {'print $2'})
ram2=$(free -h | grep -i mem | awk {'print $4'})
ram3=$(free -h | grep -i mem | awk {'print $3'})
_usor=$(printf '%-8s' "$(free -m | awk 'NR==2{printf "%.2f%%", $3*100/$2 }')")

# Funciones de Interfaz EstГ©tica de LГӯneas
msg() {
   NEGRITO='\e[1m'
   SEMCOR='\e[0m'
   COLOR[0]='\033[1;37m' # Blanco
   COLOR[1]='\e[31m'     # Rojo
   COLOR[2]='\e[32m'     # Verde
   COLOR[3]='\e[33m'     # Amarillo
   COLOR[6]='\033[1;97m' # Cyan Brillante
   
   case $1 in
   -ne) cor="${COLOR[1]}${NEGRITO}" && echo -ne "${cor}${2}${SEMCOR}" ;;
   -ama) cor="${COLOR[3]}${NEGRITO}" && echo -e "${cor}${2}${SEMCOR}" ;;
   -verm) cor="${COLOR[3]}${NEGRITO}[!] ${COLOR[1]}" && echo -e "${cor}${2}${SEMCOR}" ;;
   -azu) cor="${COLOR[6]}${NEGRITO}" && echo -e "${cor}${2}${SEMCOR}" ;;
   -verd) cor="${COLOR[2]}${NEGRITO}" && echo -e "${cor}${2}${SEMCOR}" ;;
   -bra) cor="${COLOR[0]}${SEMCOR}" && echo -e "${cor}${2}${SEMCOR}" ;;
   "-bar2" | "-bar") cor="${COLOR[1]}вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”" && echo -e "${SEMCOR}${cor}${SEMCOR}" ;;
   -tit) echo -e "\e[97m \033[1;41m| #-#-в–ә рҹҗІ SCRIPT VPS-SAMA PREMIUM в—„-#-# | \033[0;37m" ;;
   esac
}

meu_ip() {
   if [[ -e /etc/VPS-SAMA/MEUIPvps ]]; then
      echo "$(cat /etc/VPS-SAMA/MEUIPvps)"
   else
      MEU_IP=$(curl -sS https://api.ipify.org || curl -sS https://ifconfig.me/ip || wget -qO- ipinfo.io/ip)
      echo "$MEU_IP" | tr -d '[:space:]' > /etc/VPS-SAMA/MEUIPvps
      echo "$MEU_IP"
   fi
}

os_system() {
   system=$(echo $(cat -n /etc/issue | grep 1 | cut -d' ' -f6,7,8 | sed 's/1//' | sed 's/      //'))
   echo $system | awk '{print $1, $2}'
}

selection_fun() {
   local selection="null"
   local range
   for ((i = 0; i <= $1; i++)); do range[$i]="$i "; done
   while [[ ! $(echo ${range[*]} | grep -w "$selection") ]]; do
      echo -ne "\033[1;37m в–ә Selecione una Opcion: " >&2
      read selection
      tput cuu1 >&2 && tput dl1 >&2
   done
   echo $selection
}

# =========================================================
# [1] ADMINISTRAR CUENTAS (NORMAL, HWID, TOKEN) + API APPS
# =========================================================
administrar_cuentas_sama() {
   clear
   msg -bar
   # Leer la clave token guardada actualmente
   CLAVE_TOKEN_ACTUAL=$(cat /etc/VPS-SAMA/token.key)
   
   echo -e " в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ"
   echo -e " в”Ӯ\e[1;36m              AGREGAR USUARIO | VPS-SAMA                \e[0mв”Ӯ"
   echo -e " в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ"
   echo -e "   Clave Token Activa de Red:\e[1;33m $CLAVE_TOKEN_ACTUAL \e[0m"
   echo -e " вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”"
   echo -e "   [1] > NORMAL (Usuario y ContraseГұa tradicional)"
   echo -e "   [2] > HWID   (Bloqueo por ID Гәnico de celular)"
   echo -e "   [3] > TOKEN  (Crear ingresando Token manual + DueГұo)"
   echo -e "   [4] > REMOVER USUARIO O TOKEN DEL SISTEMA"
   echo -e "   [5] > LISTAR TODAS LAS CUENTAS REGISTRADAS"
   echo -e "   [6] > EDITAR / CAMBIAR LA CLAVE TOKEN FIJA"
   echo -e "   [0] > VOLVER AL MENГҡ ANTERIOR"
   msg -bar
   read -p " Seleccione una OpciГіn [0-6]: " op_db
   
   case $op_db in
   1)
      read -p " Nombre de usuario: " user
      read -p " ContraseГұa: " pass
      read -p " DГӯas de duraciГіn: " dias
      useradd -M -s /bin/false -e "$(date -d "$dias days" +"%Y-%m-%d")" $user
      echo "$user:$pass" | chpasswd
      fecha_venc=$(date -d "$dias days" +"%d/%m/%Y")
      echo "$user|NORMAL|$pass|$fecha_venc" >> /etc/VPS-SAMA/usuarios.db
      echo -e "\e[1;32m\n [+] Cuenta Normal '$user' creada hasta el $fecha_venc\e[0m"
      read -p " Presione Enter para continuar..."
      ;;
   2)
      read -p " Nombre de usuario: " user
      read -p " Pegue el HWID / ID del dispositivo: " hwid
      read -p " DГӯas de duraciГіn: " dias
      useradd -M -s /bin/false -e "$(date -d "$dias days" +"%Y-%m-%d")" $user
      echo "$user:hwidsama123" | chpasswd
      fecha_venc=$(date -d "$dias days" +"%d/%m/%Y")
      echo "$user|HWID|$hwid|$fecha_venc" >> /etc/VPS-SAMA/usuarios.db
      echo -e "\e[1;32m\n [+] Cuenta HWID vinculada con Г©xito hasta el $fecha_venc\e[0m"
      read -p " Presione Enter para continuar..."
      ;;
   3)
      read -p " Nombre del Cliente (Para saber de quiГ©n es): " cliente_nom
      read -p " Ingrese o pegue el TOKEN manual (Usuario): " token_manual
      read -p " DГӯas de duraciГіn para este Token: " dias
      
      # Usar de forma automatica la clave fija guardada en el archivo de configuracion
      clave_uni=$(cat /etc/VPS-SAMA/token.key)
      
      cliente_nom=$(echo "$cliente_nom" | sed 's/ /_/g')
      [[ -z "$cliente_nom" ]] && cliente_nom="Sin_Nombre"

      if [[ -z "$token_manual" || -z "$dias" ]]; then
         echo -e "\e[1;31m\n [-] Error: NingГәn campo puede quedar vacГӯo.\e[0m"
         read -p " Presione Enter para continuar..."
         return 0
      fi
      
      useradd -M -s /bin/false -e "$(date -d "$dias days" +"%Y-%m-%d")" $token_manual
      echo "$token_manual:$clave_uni" | chpasswd
      fecha_venc=$(date -d "$dias days" +"%d/%m/%Y")
      
      echo "$token_manual|TOKEN|$clave_uni|$fecha_venc|$cliente_nom" >> /etc/VPS-SAMA/usuarios.db
      echo -e "\e[1;32m\n [+] ВЎTOKEN REGISTRADO CON ГүXITO! \e[0m"
      echo -e "     \e[1;37mDueГұo / Cliente:\e[1;35m $cliente_nom \e[0m"
      echo -e "     \e[1;37mUsuario (Token):\e[1;36m $token_manual \e[0m"
      echo -e "     \e[1;37mContraseГұa Fija:\e[1;33m $clave_uni \e[0m"
      echo -e "     \e[1;37mVГЎlido hasta el:\e[1;32m $fecha_venc \e[0m"
      read -p " Presione Enter para continuar..."
      ;;
   4)
      read -p " Ingrese el Usuario o Token a eliminar: " user
      userdel -f $user
      sed -i "/^$user|/d" /etc/VPS-SAMA/usuarios.db
      echo -e "\e[1;31m[-] Eliminado por completo de la base de datos y del VPS.\e[0m"
      read -p " Presione Enter para continuar..."
      ;;
   5)
      clear
      echo -e "\e[1;36mв”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\e[0m"
      echo -e "\e[1;36mв”Ӯ             BASE DE DATOS COMPLETA VPS-SAMA            в”Ӯ\e[0m"
      echo -e "\e[1;36mв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ\e[0m"
      printf " \e[1;33m%-16s %-8s %-12s %-12s %-12s\e[0m\n" "USUARIO/TOKEN" "TIPO" "CLAVE" "VENCIMIENTO" "DUEГ‘O"
      echo " вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”"
      if [ -f /etc/VPS-SAMA/usuarios.db ]; then
          while IFS='|' read -r u t c v n; do
              [[ -z "$n" ]] && n="вҖ”"
              printf " %-16s %-8s %-12s %-12s %-12s\n" "$u" "$t" "$c" "$v" "$n"
          done < /etc/VPS-SAMA/usuarios.db
      fi
      echo " вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”вҖ”"
      read -p " Presione Enter para continuar..."
      ;;
   6)
      read -p " Ingrese la NUEVA Clave Fija para los Tokens: " nueva_key
      if [ ! -z "$nueva_key" ]; then
         echo "$nueva_key" > /etc/VPS-SAMA/token.key
         echo -e "\e[1;32m\n [+] Clave Universal actualizada a: $nueva_key\e[0m"
      else
         echo -e "\e[1;31m\n [-] Cancelado. La clave no puede estar en blanco.\e[0m"
      fi
      read -p " Presione Enter para continuar..."
      ;;
   *) return 0 ;;
   esac
}

