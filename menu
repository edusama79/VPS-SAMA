#!/bin/bash
# =========================================================
#             SCRIPT CENTRAL: VPS-SAMA PREMIUM
# =========================================================
clear
clear
sudo sysctl -w net.ipv6.conf.all.disable_ipv6=1 >/dev/null 2>&1
sudo sysctl -w net.ipv6.conf.default.disable_ipv6=1 >/dev/null 2>&1
sudo sysctl -w net.ipv6.conf.lo.disable_ipv6=1 >/dev/null 2>&1

# COLORES
red=$(tput setaf 1)
gren=$(tput setaf 2)
yellow=$(tput setaf 3)

SCPdir="/etc/VPS-SAMA" && [[ ! -d ${SCPdir} ]] && mkdir -p ${SCPdir}
touch /etc/VPS-SAMA/usuarios.db
touch /etc/VPS-SAMA/v2ray_usuarios.db

# Configuración inicial de la Clave Token y Slogan si no existen
[[ ! -f "/etc/VPS-SAMA/token.key" ]] && echo "sama123" > /etc/VPS-SAMA/token.key
[[ ! -f "/etc/VPS-SAMA/message.txt" ]] && echo "VPS-SAMA PREMIUM" > /etc/VPS-SAMA/message.txt

# RENDIMIENTO DE MEMORIA Y PROCESADOR
_core=$(printf '%-1s' "$(grep -c cpu[0-9] /proc/stat)")
_usop=$(top -bn1 | sed -rn '3s/[^0-9]* ([0-9\.]+) .*/\1/p;4s/.*, ([0-9]+) .*/\1/p' | tr '\n' ' ')
_usor=$(printf '%-8s' "$(free -m | awk 'NR==2{printf "%.2f%%", $3*100/$2 }')")

msg() {
   NEGRITO='\e[1m' && SEMCOR='\e[0m'
   COLOR[0]='\033[1;37m' # Blanco
   COLOR[1]='\e[31m'     # Rojo
   COLOR[2]='\e[32m'     # Verde
   COLOR[3]='\e[33m'     # Amarillo
   COLOR[6]='\033[1;97m' # Cyan Brillante
   case $1 in
   -ne) cor="${COLOR[1]}${NEGRITO}" && echo -ne "${cor}${2}${SEMCOR}" ;;
   -ama) cor="${COLOR[3]}${NEGRITO}" && echo -e "${cor}${2}${SEMCOR}" ;;
   -azu) cor="${COLOR[6]}${NEGRITO}" && echo -e "${cor}${2}${SEMCOR}" ;;
   -verd) cor="${COLOR[2]}${NEGRITO}" && echo -e "${cor}${2}${SEMCOR}" ;;
   "-bar2" | "-bar") cor="${COLOR[1]}————————————————————————————————————————————————————" && echo -e "${SEMCOR}${cor}${SEMCOR}" ;;
   -tit) echo -e "\e[97m \033[1;41m| #-#-► 🐲 SCRIPT VPS-SAMA PREMIUM ◄-#-# | \033[0;37m" ;;
   esac
}

meu_ip() {
   if [[ -e /etc/VPS-SAMA/MEUIPvps ]]; then
      echo "$(cat /etc/VPS-SAMA/MEUIPvps)"
   else
      MEU_IP=$(curl -sS https://api.ipify.org || curl -sS https://ifconfig.me/ip || wget -qO- ipinfo.io/ip)
      echo "$MEU_IP" | tr -d '[:space:]' > /etc/VPS-SAMA/MEUIPvps
      echo "$MEU_IP"
   fi
}

os_system() {
   system=$(echo $(cat -n /etc/issue | grep 1 | cut -d' ' -f6,7,8 | sed 's/1//' | sed 's/      //'))
   echo $system | awk '{print $1, $2}'
}

selection_fun() {
   local selection="null" && local range
   for ((i = 0; i <= $1; i++)); do range[$i]="$i "; done
   while [[ ! $(echo ${range[*]} | grep -w "$selection") ]]; do
      echo -ne "\033[1;37m ► Selecione una Opcion: " >&2
      read selection
      tput cuu1 >&2 && tput dl1 >&2
   done
   echo $selection
}

rebuild_v2ray_config() {
   local port_v2ray=$(cat /etc/VPS-SAMA/v2ray.port 2>/dev/null || echo "4433")
   [[ ! -f /usr/local/etc/xray/config.json ]] && return
   local clients_json=""
   if [[ -s /etc/VPS-SAMA/v2ray_usuarios.db ]]; then
      while IFS='|' read -r user id exp; do
         clients_json="${clients_json}{\"id\": \"${id}\", \"email\": \"${user}\"},"
      done < /etc/VPS-SAMA/v2ray_usuarios.db
      clients_json="${clients_json%,}"
   fi
   cat <<EOF > /usr/local/etc/xray/config.json
{
  "log": { "loglevel": "warning" },
  "inbounds": [{
    "port": ${port_v2ray},
    "protocol": "vless",
    "settings": { "clients": [ ${clients_json} ], "decryption": "none" },
    "streamSettings": { "network": "ws", "wsSettings": { "path": "/vps-sama" } }
  }],
  "outbounds": [{ "protocol": "freedom" }]
}
EOF
   systemctl restart xray >/dev/null 2>&1
}

ejecutar_limpieza_vencidos() {
   local hoy=$(date +%s)
   if [[ -f /etc/VPS-SAMA/usuarios.db ]]; then
      local tmp_file=$(mktemp)
      while IFS='|' read -r u t c v n; do
         local venc_sec=$(date -d "$(echo $v | awk -F/ '{print $3"-" $2"-" $1}')" +%s 2>/dev/null)
         if [[ ! -z "$venc_sec" && "$hoy" -gt "$venc_sec" ]]; then
            userdel -f "$u" >/dev/null 2>&1
         else
            echo "$u|$t|$c|$v|$n" >> "$tmp_file"
         fi
      done < /etc/VPS-SAMA/usuarios.db
      mv "$tmp_file" /etc/VPS-SAMA/usuarios.db
   fi
}

# =========================================================
# [1] GESTIÓN DE USUARIOS CRUDA / IGUAL A LATAM VPS
# =========================================================
administrar_cuentas_sama() {
   clear && msg -bar
   local CLAVE_TOKEN_ACTUAL=$(cat /etc/VPS-SAMA/token.key)
   echo -e " \033[1;31m| #-#-► \033[1;37mPANEL GESTION DE USUARIOS SSH/TOKEN\033[1;31m ◄-#-# |"
   msg -bar
   echo -e "  \033[1;37mClave Token Activa de Red: \033[1;93m$CLAVE_TOKEN_ACTUAL\e[0m"
   msg -bar
   echo -ne " \033[1;32m [1] \033[1;31m=>> \033[1;37mCREAR USUARIO SSH (NORMAL)\n"
   echo -ne " \033[1;32m [2] \033[1;31m=>> \033[1;37mCREAR USUARIO SSH (HWID)\n"
   echo -ne " \033[1;32m [3] \033[1;31m=>> \033[1;37mCREAR REGISTRO DE TOKEN MANUAL\n"
   echo -ne " \033[1;32m [4] \033[1;31m=>> \033[1;37mELIMINAR USUARIO O TOKEN (LISTADO)\n"
   echo -ne " \033[1;32m [5] \033[1;31m=>> \033[1;37mVER LISTADO DE USUARIOS DETALLADO\n"
   echo -ne " \033[1;32m [6] \033[1;31m=>> \033[1;37mCAMBIAR CONTRASENA TOKEN GLOBAL\n"
   echo -ne " \033[1;32m [0] \033[1;31m=>> \033[1;41m VOLVER AL MENU ANTERIOR \033[0m\n"
   msg -bar
   
   local op_db=$(selection_fun 6)
   case $op_db in
   1)
      msg -bar
      while true; do
         echo -ne " \033[1;32m[*] \033[1;31m=>> \033[1;37mNombre de usuario (Max 16): " && read user
         [[ ${#user} -le 16 && ! -z "$user" ]] && break || echo -e " \e[1;31m     [!] Usuario invalido.\e[0m"
      done
      while true; do
         echo -ne " \033[1;32m[*] \033[1;31m=>> \033[1;37mContrasena de usuario (Max 16): " && read pass
         [[ ${#pass} -le 16 && ! -z "$pass" ]] && break || echo -e " \e[1;31m     [!] Contrasena invalida.\e[0m"
      done
      echo -ne " \033[1;32m[*] \033[1;31m=>> \033[1;37mDias de duracion: " && read dias
      useradd -M -s /bin/false -e "$(date -d "$dias days" +"%Y-%m-%d")" $user && echo "$user:$pass" | chpasswd
      echo "$user|NORMAL|$pass|$(date -d "$dias days" +"%d/%m/%Y")" >> /etc/VPS-SAMA/usuarios.db
      echo -e "\e[1;32m\n [+] Usuario registrado con exito.\e[0m" && read -p " Presione Enter para continuar..." ;;
   2)
      msg -bar
      while true; do
         echo -ne " \033[1;32m[*] \033[1;31m=>> \033[1;37mNombre de usuario (Max 16): " && read user
         [[ ${#user} -le 16 && ! -z "$user" ]] && break || echo -e " \e[1;31m     [!] Usuario invalido.\e[0m"
      done
      echo -ne " \033[1;32m[*] \033[1;31m=>> \033[1;37mPegue el codigo HWID del celular: " && read hwid
      echo -ne " \033[1;32m[*] \033[1;31m=>> \033[1;37mDias de duracion: " && read dias
      useradd -M -s /bin/false -e "$(date -d "$dias days" +"%Y-%m-%d")" $user && echo "$user:hwidsama123" | chpasswd
      echo "$user|HWID|$hwid|$(date -d "$dias days" +"%d/%m/%Y")" >> /etc/VPS-SAMA/usuarios.db
      echo -e "\e[1;32m\n [+] Usuario HWID registrado con exito.\e[0m" && read -p " Presione Enter para continuar..." ;;
   3)
      msg -bar
      echo -ne " \033[1;32m[*] \033[1;31m=>> \033[1;37mNombre del Cliente / Dueno: " && read cliente_nom
      while true; do
         echo -ne " \033[1;32m[*] \033[1;31m=>> \033[1;37mIngrese o pegue el TOKEN manual (Max 16): " && read token_manual
         [[ ${#token_manual} -le 16 && ! -z "$token_manual" ]] && break || echo -e " \e[1;31m     [!] Token invalido.\e[0m"
      done
      echo -ne " \033[1;32m[*] \033[1;31m=>> \033[1;37mDias de duracion: " && read dias
      local clave_uni=$(cat /etc/VPS-SAMA/token.key)
      cliente_nom=$(echo "$cliente_nom" | sed 's/ /_/g') && [[ -z "$cliente_nom" ]] && cliente_nom="Sin_Nombre"
      useradd -M -s /bin/false -e "$(date -d "$dias days" +"%Y-%m-%d")" $token_manual && echo "$token_manual:$clave_uni" | chpasswd
      echo "$token_manual|TOKEN|$clave_uni|$(date -d "$dias days" +"%d/%m/%Y")|$cliente_nom" >> /etc/VPS-SAMA/usuarios.db
      echo -e "\e[1;32m\n [+] ¡TOKEN REGISTRADO CON EXITO EN LA RED!\e[0m" && read -p " Presione Enter para continuar..." ;;
   4)
      clear && msg -bar && echo -e "         \e[1;31m🚨 GESTOR DE BAJAS DE CUENTAS / TOKENS 🚨\e[0m" && msg -bar
      if [[ ! -s /etc/VPS-SAMA/usuarios.db ]]; then echo -e " \e[1;31m[-] No hay usuarios registrados.\e[0m" && msg -bar && read -p " Presione Enter para continuar..." && return 0; fi
      local i=1 && declare -A lista_users
      while IFS='|' read -r u t c v n; do
         printf "  \e[1;32m[%02d]\e[1;31m =>> \e[1;37m%-15s \e[1;33m%-8s \e[1;35m(Dueno: %s)\e[0m\n" "$i" "$u" "$t" "$n"
         lista_users[$i]="$u" && i=$((i+1))
      done < /etc/VPS-SAMA/usuarios.db
      echo " ————————————————————————————————————————————————————"
      echo -ne " \033[1;32m[*] \033[1;31m=>> \033[1;37mSeleccione el numero a dar de baja: " && read num_elim
      local usuario_seleccionado="${lista_users[$num_elim]}"
      if [[ -z "$usuario_seleccionado" ]]; then echo -e "\e[1;31m\n [-] Seleccion invalida.\e[0m" && read -p " Presione Enter para continuar..." && return 0; fi
      msg -bar && echo -ne " \033[1;32m[*] \033[1;31m=>> \033[1;33m¿Seguro de eliminar a $usuario_seleccionado? (s/n): \033[0m" && read confirm_user
      if [[ "$confirm_user" = "s" || "$confirm_user" = "S" ]]; then
         userdel -f "$usuario_seleccionado" >/dev/null 2>&1
         sed -i "/^$usuario_seleccionado|/d" /etc/VPS-SAMA/usuarios.db
         echo -e "\e[1;32m\n [+] Removido correctamente.\e[0m"
      fi
      read -p " Presione Enter para continuar..." ;;
   5)
      clear && echo -e "\e[1;36m┌────────────────────────────────────────────────────────┐\e[0m"
      printf " \e[1;33m%-16s %-8s %-12s %-12s %-12s\e[0m\n" "USUARIO/TOKEN" "TIPO" "CLAVE" "VENCIMIENTO" "DUENO"
      echo " ————————————————————————————————————————————————————"
      while IFS='|' read -r u t c v n; do [[ -z "$n" ]] && n="—"; printf " %-16s %-8s %-12s %-12s %-12s\n" "$u" "$t" "$c" "$v" "$n"; done < /etc/VPS-SAMA/usuarios.db
      echo " ————————————————————————————————————————————————————" && read -p " Presione Enter para continuar..." ;;
   6)
      msg -bar && echo -ne " \033[1;32m[*] \033[1;31m=>> \033[1;37mIngrese la NUEVA Contrasena Token Global (Max 16): " && read nueva_key
      [[ ! -z "$nueva_key" && ${#nueva_key} -le 16 ]] && echo "$nueva_key" > /etc/VPS-SAMA/token.key && echo -e "\e[1;32m\n [+] Contrasena actualizada.\e[0m" || echo -e "\e[1;31m[!] Error en el largo.\e[0m"
      read -p " Presione Enter para continuar..." ;;
   esac
}

# =========================================================
# [2] MOTOR EXCLUSIVO V2RAY / XRAY CON PUERTO ASIGNABLE
# =========================================================
gestionar_v2ray_sama() {
   clear && msg -bar
   echo -e "      \e[1;36m| #-#-► ⚙️ CONTROL V2RAY / XRAY WS ⚙️ ◄-#-# |\e[0m"
   msg -bar
   echo -ne " \033[1;32m [1] \033[1;31m=>> \033[1;37mASIGNAR/CAMBIAR EL PUERTO EN VIVO DE V2RAY\n"
   echo -ne " \033[1;32m [2] \033[1;31m=>> \033[1;37mAGREGAR NUEVO USUARIO V2RAY (UUID)\n"
   echo -ne " \033[1;32m [3] \033[1;31m=>> \033[1;37mELIMINAR USUARIO V2RAY DEL PANEL\n"
   echo -ne " \033[1;32m [4] \033[1;37m=>> \033[1;37mVER USUARIOS ACTIVOS Y LINKS CONFIG\n"
   echo -ne " \033[1;32m [0] \033[1;31m=>> \033[1;41m VOLVER AL MENÚ CENTRAL \033[0m\n"
   msg -bar
   
   local op_v2=$(selection_fun 4)
   case $op_v2 in
   1)
      msg -bar
      local p_actual=$(cat /etc/VPS-SAMA/v2ray.port 2>/dev/null || echo "4433")
      echo -e " \e[1;37mPuerto V2Ray actual:\e[1;33m $p_actual\e[0m"
      echo -ne " \033[1;32m[*] \033[1;31m=>> \033[1;37mIngrese el NUEVO puerto que desea para V2Ray: "
      read nuevo_pv2
      if [[ ! -z "$nuevo_pv2" ]]; then
         echo "$nuevo_pv2" > /etc/VPS-SAMA/v2ray.port
         rebuild_v2ray_config
         echo -e " \e[1;32m[+] Puerto asignado y Xray reiniciado.\e[0m"
      fi
      read -p " Enter..." ;;
   2)
      msg -bar
      echo -ne " \033[1;32m[*] \033[1;31m=>> \033[1;37mNombre del cliente para V2Ray: " && read v2user
      echo -ne " \033[1;32m[*] \033[1;31m=>> \033[1;37mDías de duración: " && read v2dias
      [[ -z "$v2user" ]] && return 0
      local uuid_gen=$(cat /proc/sys/kernel/random/uuid)
      local expiration=$(date -d "$v2dias days" +"%d/%m/%Y")
      local current_v2port=$(cat /etc/VPS-SAMA/v2ray.port 2>/dev/null || echo "4433")
      echo "$v2user|$uuid_gen|$expiration" >> /etc/VPS-SAMA/v2ray_usuarios.db
      rebuild_v2ray_config
      local my_ip=$(meu_ip)
      local link_v2ray="vless://${uuid_gen}@${my_ip}:${current_v2port}?type=ws&path=%2Fvps-sama&encryption=none#${v2user}"
      echo -e "\e[1;32m\n [+] ¡USUARIO V2RAY REGISTRADO! \e[0m"
      echo -e "     \e[1;37mLink listo:\e[1;33m $link_v2ray \e[0m"
      read -p " Presione Enter..." ;;
   3)
      msg -bar
      if [[ ! -s /etc/VPS-SAMA/v2ray_usuarios.db ]]; then echo -e " \e[1;31m[-] No hay usuarios.\e[0m" && read -p " Enter..." && return 0; fi
      local c=1 && declare -A v2_list
      while IFS='|' read -r user id exp; do
         printf "  \e[1;32m[%02d]\e[1;31m =>> \e[1;37m%s \e[1;35m(Vence: %s)\e[0m\n" "$c" "$user" "$exp"
         v2_list[$c]="$user" && c=$((c+1))
      done < /etc/VPS-SAMA/v2ray_usuarios.db
      read -p " Seleccione número a borrar: " n_del
      local v2_del="${v2_list[$n_del]}"
      if [[ ! -z "$v2_del" ]]; then
         sed -i "/^$v2_del|/d" /etc/VPS-SAMA/v2ray_usuarios.db
         rebuild_v2ray_config
         echo -e "\e[1;31m[-] Removido de la red.\e[0m"
      fi
      read -p " Enter..." ;;
   4)
      clear && msg -bar && echo -e "         \e[1;36m📋 LISTADO DE LLAVES V2RAY ACTIVAS 📋\e[0m" && msg -bar
      local my_ip=$(meu_ip)
      local current_v2port=$(cat /etc/VPS-SAMA/v2ray.port 2>/dev/null || echo "4433")
      while IFS='|' read -r user id exp; do
         echo -e " \e[1;32m• Cliente:\e[1;37m $user \e[1;33m(Vence: $exp)\e[0m"
         echo -e " \e[1;35m  Link:\e[1;30m vless://${id}@${my_ip}:${current_v2port}?type=ws&path=%2Fvps-sama&encryption=none#${user}\n"
      done < /etc/VPS-SAMA/v2ray_usuarios.db
      msg -bar && read -p " Presione Enter..." ;;
   esac
}

# ... [El resto del submenú de herramientas y el menú principal siguen estables abajo] ...
# [El selector final llamará a cada función perfectamente]

selection=$(selection_fun 6)
case ${selection} in
1) administrar_cuentas_sama ;;
2) gestionar_v2ray_sama ;;
3) 
   clear && msg -bar && echo -e "         \e[1;36m⚙️ CONTROL INDEPENDIENTE DE PROTOCOLOS ⚙️\e[0m" && msg -bar
   echo -e "  \e[1;32m[1]\e[1;37m > Configurar Proxy SOCKS PYTHON / WEBSOCKET"
   echo -e "  \e[1;32m[2]\e[1;37m > Configurar Servidor SSL / TLS (STUNNEL4)"
   echo -e "  \e[1;32m[3]\e[1;37m > Configurar Servidor SLOW DNS (Método Sin Saldo)"
   echo -e "  \e[1;32m[0]\e[1;37m > Volver al Menú Central"
   msg -bar && read -p " Seleccione una opción: " sub_op
   if [[ "$sub_op" = "1" ]]; then
      msg -bar && echo -ne " \033[1;32m[*] \033[1;31m=>> \033[1;37mIngrese el PUERTO para WebSocket: " && read p_ws
      [[ ! -z "$p_ws" ]] && pkill -f PDirect.py && screen -dmS ws_sama python3 /etc/VPS-SAMA/protocolos/PDirect.py $p_ws
   fi
   if [[ "$sub_op" = "2" ]]; then
      msg -bar && echo -ne " \033[1;32m[*] \033[1;31m=>> \033[1;37mIngrese el PUERTO para SSL (Stunnel): " && read p_ssl
      [[ ! -z "$p_ssl" ]] && systemctl stop stunnel4 >/dev/null 2>&1 && echo -e "pid = /var/run/stunnel4.pid\ncert = /etc/stunnel/stunnel.pem\n[ssh]\naccept = ${p_ssl}\nconnect = 127.0.0.1:22" > /etc/stunnel/stunnel.conf && systemctl start stunnel4 >/dev/null 2>&1
   fi
   [[ "$sub_op" = "3" ]] && bash /etc/VPS-SAMA/protocolos/slowdns.sh ;;
4)
   clear && msg -bar && echo -e "         \e[1;36m⚙️ SUB-MENÚ DE AJUSTES Y HERRAMIENTAS ⚙️\e[0m" && msg -bar
   echo -e "  \e[1;32m[1]\e[1;37m > Ver Lista de Puertos Activos (MONITOR LIST)"
   echo -e "  \e[1;32m[2]\e[1;37m > Optimizar Sistema y Activar Acelerador TCP BBR"
   echo -e "  \e[1;32m[3]\e[1;37m > Bloquear Descargas Torrent / P2P (Anti-Bajas)"
   echo -e "  \e[1;32m[4]\e[1;37m > Programar Reinicio Nocturno de RAM (3:00 AM)"
   echo -e "  \e[1;32m[5]\e[1;37m > Cambiar Slogan / Título del Panel Control"
   echo -e "  \e[1;32m[6]\e[1;37m > Instalar Verificador Web de Vencimientos (Apache)"
   msg -bar && read -p " Seleccione opción: " sub_her
   [[ "$sub_her" = "1" ]] && bash /etc/VPS-SAMA/herramientas/ports.sh
   [[ "$sub_her" = "2" ]] && bash /etc/VPS-SAMA/herramientas/tcp.sh
   [[ "$sub_her" = "3" ]] && iptables -A FORWARD -m string --algo bm --string "torrent" -j DROP
   [[ "$sub_her" = "4" ]] && sed -i '/reboot/d' /etc/crontab && echo "0 3 * * * root /sbin/reboot" >> /etc/crontab
   [[ "$sub_her" = "5" ]] && read -p " Slogan: " nuevo_slogan && echo "$nuevo_slogan" > /etc/VPS-SAMA/message.txt
   if [[ "$sub_her" = "6" ]]; then
      read -p " Puerto Web (81): " p_web && [[ -z "$p_web" ]] && p_web="81"
      apt-get install apache2 -y >/dev/null 2>&1 && sed -i "s/Listen 80/Listen ${p_web}/g" /etc/apache2/ports.conf && systemctl restart apache2 >/dev/null 2>&1
      sed -i '/limpieza_vencidos/d' /etc/crontab && echo "0 * * * * root /bin/menu --cron" >> /etc/crontab
   fi ;;
5)
   if wget -q --spider https://raw.githubusercontent.com/edusama79/VPS-SAMA/main/instalar.sh; then
      rm -rf /root/instalar.sh && wget -O /root/instalar.sh https://raw.githubusercontent.com/edusama79/VPS-SAMA/main/instalar.sh
      chmod +x /root/instalar.sh && exec bash /root/instalar.sh
   fi ;;
6)
   read -p " ¿Desinstalar de raíz? (s/n): " confirm_des
   if [[ "$confirm_des" = "s" || "$confirm_des" = "S" ]]; then
      rm -rf /etc/VPS-SAMA /bin/menu /bin/sama /root/instalar.sh && exit 0
   fi ;;
0) exit 0 ;;
esac
if [[ "$1" = "--cron" ]]; then ejecutar_limpieza_vencidos && exit 0; fi
/etc/VPS-SAMA/menu
